--    Type:          Form Definition
--    Group:         Design
--      Keyword:     Clash
--    Module:        Design
--  Author:          Star Soft (Adapted Steve Bentley)
--  Created:         Fri Mar 19 13:17:59 2010
--
--  Description:     Clasher GUI
--
------------------------------------------------------------------------
--
-- Methods defined:
--
--  Method call                      Return              Description
--  ===========                      ======              ===========
--  activeInactiveClipOptions()      -                   Activate or deactivate clip options
--  activeInactiveReportOptions()    -                   Activate or deactivate report options
--  avaclasherui()                   -                   Constructor
--  batchClashCallback()             -                   Callback for batch laser clash option
--  buttonInitControl()              -
--  ceCallback()                     -                   Clash CE text box callback
--  check(ARRAY)                     -
--  check(DBREF)                     -
--  checkSupport(BOOLEAN)            -                   provide a list of supports to be checked by .checkSupportList()
--  checkSupportList()               -                   return from picking supports to clash and check
--  clipClash()                      -
--  dismiss()                        -
--  displayClashes()                 -
--  displayExcl()                    -
--  displayObst()                    -
--  edgCallback()                    -                   return from picking supports to clash and check
--  exclListAdd()                    -
--  exclListAddCE()                  -
--  exclListAddElements(ARRAY)       -
--  exclListAddList()                -
--  exclListAddSelection()           -
--  exclListClear()                  -
--  exclListInitGraphicalSelection() -
--  exclListRemove()                 -
--  exclListRestore()                -                   Restore exclusion list from file
--  exclListSave()                   -                   Save exclusion list to file
--  fileBrowserLoad()                -                   Load the PML fileBrowser to Save the location of the Report File
--  fileName()                       STRING              gets the file name to output the grid data
--  findClashes(ARRAY)               -                   Find clashes for element and displays them in the clash list.
--  firstShown()                     -
--  fullLimitsClear()                -                   Clears the limits - sets to 0.
--  getCurrentPdmsList()             ARRAY
--  getCurrentSelection()            ARRAY
--  getCurrentXGEOMList()            ARRAY
--  getIgnored()                     -
--  getOptions()                     -
--  getResults()                     -
--  getSections()                    -
--  getSetLimits()                   -                   Gets and sets the limits
--  graphicalSelectionHandler(DBREF) -
--  groupOptionCallback()            -                   Group the clashes option
--  highlight(DBREF,REAL,BOOLEAN)    -                   return from picking supports to clash and check
--  init()                           -
--  limitsClear()                    -
--  limitsDisplay()                  -
--  limitsGraphicalSelectionFinished() -
--  limitsInitGraphicalSelection()   -
--  limitsOriginsGraphicalSelectionFinished(POSITION,POSITION) -
--  limitsOriginsInitGraphicalSelection() -
--  limitsOriginsSecondGraphicalSelection(POSITION) -
--  limitsSet()                      -
--  limitsSetCE()                    -
--  limitsSetCoordinates()           -
--  limitsSetList()                  -
--  limitsSetSelection()             -                   Sets limits by calculating enclosing box of items from Current Selection.
--  limitsStorePositions()           -
--  modelContainsCloudPointClouds()  -                   Searches for cloud data sets
--  netAfterSelectChangeCallback(ARRAY) -
--  netPopupMainCallback(ARRAY)      -                   main grid popup callback
--  obstExclGraphicalSelectionFinished(STRING) -
--  obstExclInitGraphicalSelection(STRING) -
--  obstListAdd()                    -
--  obstListAddAll()                 -
--  obstListAddCE()                  -
--  obstListAddElement(DBREF)        -
--  obstListAddElements(ARRAY)       -
--  obstListAddLaser()               -
--  obstListAddList()                -
--  obstListAddSelection()           -
--  obstListClear()                  -
--  obstListInitGraphicalSelection() -
--  obstListRemove()                 -
--  posControl()                     -                   Method called every time the posControl gadgets change via the .changeAction
--  remButtonActiveNot(GADGET,STRING) -
--  remExclButtonActive()            -
--  remObsButtonActive()             -
--  restoreDefaults()                -
--  restoreSavedOptions(STRING,STRING,BOOLEAN) -                   Restores the saved File, Saved based on GUI selections.
--  saveMain(STRING)                 -                   Saves the main grid to an excel file
--  saveOptions()                    -
--  saveReportOptions()              -
--  setColorOptions(REAL)            -
--  setIgnored()                     -
--  setOptions()                     -
--  setReportOptions()               -
--  setSections()                    -
--  setSections(STRING,STRING)       -
--  showClashes(DBREF)               -                   Fill grid with clashes
--  sliderCallback(ANY,STRING)       -                   parameter change callback
--  tabsetCallback()                 -                   Method invoked when tab in tabset is selected
--  tag(POSITION,POSITION)           -                   Tag position
--  updateBatchClashOption()         -                   Sets the batch clash option box

import 'GridControl'
handle any
endhandle
import 'PositionControl'
handle ANY
endhandle
import 'PMLFileBrowser'
handle any
endhandle
import 'PMLNetUtilities'
handle any
endhandle

-- Form definition

-- Make sure avaclasherui can be used only in Design
if (!!cdcnmod neq 'DESIGN') then
  !formMode = 'NOQUIT'
else
  !formMode = 'RESIZE DOCUMENT FLOAT'
endif

--------------------------------------
layout form !!avaclasherui $!formMode
  --------------------------------------

  if (!!cdcnmod neq 'DESIGN') then

    frame .frmNotDesign width 10 height 3.5
      para .parNotDesign at xmin+10 text 'The Clasher form can only be used in MODEL'
      path down
      button .btnNotDesign at xmin+12 'OK' OK
    exit
    --     exit

  else

    --   layout form !!avaclasherui document

    --Form data
    !this.formTitle      = 'Clashes'
    !this.initCall       = '!this.init()'
    !this.firstShownCall = '!this.firstShown()'
    !this.quitcall       = '!this.dismiss()'

    --Form definition
    path down
    vdist 0.2
    hdist 0.2
    paragraph .selectedParagraph anchor L+T+R text '' width 131 lines 1
    button    .btnRefresh 'Check' linklabel callback '!this.check(!this.parClash.val.dbref())'
    text .parClash anchor T+L at ymin.btnRefresh  callback '!this.ceCallback()' width to max.selectedParagraph * 0.5 is STRING
    button    .btnCE 'Check CE' linklabel callback '!this.check(!!ce)'
    path right
    button  .btnSupport 'Check Support'  at xmax+3 ymin.btnCE linklabel callback |!this.checkSupport(true)|
    paragraph .parSupportSelected at ymin.btnCE + 0.2 text '' width 23 lines 1
    button  .btnSupportRecheck 'Recheck Support'  at xmax.parClash - SIZE ymin.btnCE linklabel callback |!this.checkSupport(false)|

    toggle .tglPresentClashItemA     at xmin.btnCE+3 ymax Anchor L+T 'Clash Item Aid' callback '!this.tglPresentClashItem.val = !this.tglPresentClashItemA.val
    !this.netAfterSelectChangeCallback(!this.dbCtrl.getSelectedRows())'
    toggle .tglPresentObstructionA   at xmax+2 ymin Anchor L+T 'Clash Obstruction Aid'  callback '!this.tglPresentObstruction.val = !this.tglPresentObstructionA.val
    !this.netAfterSelectChangeCallback(!this.dbCtrl.getSelectedRows())'
    toggle .tglPresentClashPositionA at xmax+2 ymin Anchor L+T 'Clash Position Aid'     callback '!this.tglPresentClashPosition.val = !this.tglPresentClashPositionA.val
    !this.netAfterSelectChangeCallback(!this.dbCtrl.getSelectedRows())'

    path down

    --Define the Clashes frame
    -- ------------ Clash List ------------
    !listCol = 63
    -- !viewCol = 60
    frame .flist TABSET at x 0 ymax+0.2 anchor T+L width $!listCol height 25

      frame .frmData 'Clashes'

        toggle .togNav at x1 ymin+0.2 |Navigate :|  call |!this.optNav.active = !this.togNav.val|
        option .optNav Anchor L+T at xmax ymin callback '' width 11

        using namespace 'Aveva.Core.Presentation'

        -- define PML Container to host my .net control
        container .netFrame PMLNetCONTROL 'NET' at x1 ymax+0.2 Anchor L+T height 24 width $!listCol
      exit

      --Define the Obstructions/Exclusions frame
      frame .frmObstructions  'Obstructions/Exclusions'  at x0 y0

        para .frmObst at x1 y0.5 text 'Obstructions'
        list    .lstObst       at x1 ymax Anchor L+R+T   callback '!this.remObsButtonActive()' columns single zerosel height 16 width 55
        button  .btnObstAdd   at xmin ymax+0.2 Anchor L+T     'Add' callback '!this.obstListAdd()'
        option  .optObstAdd   Anchor L+T              at xmax.btnObstAdd+1.5 ymin    width 18
        button  .btnObstRem   Anchor L+T     'Remove' at xmax.optObstAdd+1.5 ymin    callback '!this.obstListRemove()' width 6
        button  .btnObstClear Anchor L+T     'Clear'  at xmax.btnObstRem+1.5 ymin    callback '!this.obstListClear()' width 6

        para .frmExcl at x1 ymax+0.5 text 'Exclusions'
        list    .lstExcl       at x1 ymax Anchor L+R+T callback '!this.remExclButtonActive()' columns single zerosel height 16 width 55
        button  .btnExclAdd   at xmin ymax+0.2 Anchor L+T     'Add'    callback '!this.exclListAdd()'
        option  .optExclAdd   Anchor L+T              at xmax.btnExclAdd+1.5 ymin  width 18
        button  .btnExclRem   Anchor L+T     'Remove' at xmax.optExclAdd+1.5 ymin  callback '!this.exclListRemove()' width 6
        button  .btnExclClear Anchor L+T     'Clear'  at xmax.btnExclRem+1.5 ymin  callback '!this.exclListClear()' width 6
        button  .btnExclSave  Anchor L+T     'Save'   at x1 ymax+0.2   callback '!this.exclListSave()' width 6
        button  .btnExclRestore  Anchor L+T  'Restore'at xmax.btnExclSave+1.5 ymin  callback '!this.exclListRestore()' width 6

      exit

      frame .frLimits 'Limits' at x0 y0
        --Define the Limits frame
        frame .frmLimits 'Check for Clashes within set Limits only' at x1 y1

          paragraph .parFrom at x1 y1 text 'From:'

          frame .fromPositionControl panel  anchor left + right + top at x4 ymax width 40 height 5
            container .fromPositionContainer NOBOX PMLNetCONTROL 'NET' dock fill
          exit

          paragraph .parTo at x1 ymax+1 text 'To:'

          frame .toPositionControl panel  anchor left + right + top at x4 ymax width 40 height 5
            container .toPositionContainer NOBOX PMLNetCONTROL 'NET' dock fill
          exit

          option .optLimitsSet 'Volume' Anchor L+T at x1 ymax+1  callback '!this.limitsSet()' width 19
          button .btnLimitsClear Anchor L+T at xmax+1 ymin 'Clear' callback '!this.fullLimitsClear()'
          toggle .togLimitsAids  Anchor L+T 'Display' callback '!this.limitsDisplay()' at xmax+1 ymin
        exit

      exit

      --Define the Options frame
      frame .frmOptions 'Options'  at x0 y0

        --Define a tolerances frame
        frame .frmTolerances 'Tolerances'   at x1 y0.5

          para .parGap  at x1        text 'Touch Gap'      width 15
          para .parOvr  at xmin ymax+.6  text 'Overlap'    width 15
          para .parClr  at xmin ymax+.6  text 'Clearance'  width 15
          text .txtGap '' at xmax.parGap ymin.parGap callback'!this.setOptions()' width 12 is REAL format !!distanceFmt
          text .txtOvr '' at xmax.parOvr ymin.parOvr callback'!this.setOptions()' width 12 is REAL format !!distanceFmt
          text .txtClr '' at xmax.parClr ymin.parClr callback'!this.setOptions()' width 12 is REAL format !!distanceFmt
        exit

        --Define a Clash options frame
        frame .frmClashOptions 'Clash options'    at x1 ymax+0.25

          para   .parTch at x1           Anchor L+T text 'Touches are'              width 15
          para   .parCwb at xmin ymax+.6 Anchor L+T text 'Clashes within branch'    width 15
          para   .parCon at xmin ymax+.6 Anchor L+T text 'Connections'              width 15
          toggle .tglCmp at xmin ymax+.6 Anchor L+T 'Clash midpoint position' callback'!this.setOptions()'
          option .optTch Anchor L+T at xmax.parTch ymin.parTch callback'!this.setOptions()' width 10
          option .optCwb Anchor L+T at xmax.parCwb ymin.parCwb callback'!this.setOptions()' width 10
          option .optCon Anchor L+T at xmax.parCon ymin.parCon callback'!this.setOptions()' width 10

        exit

        --Define a Clash options frame
        frame .frmLaserOptions 'Point Cloud options'    at x1 ymax+0.25
          para   .paraLaserTest    Anchor L+T at x1         text 'Test Data'      width 15
          para   .paraLaserDisplay Anchor L+T at x1 ymax+.6 text 'Display Result' width 15
          option .optLaserTest     Anchor L+T at xmax.paraLaserTest ymin.paraLaserTest    callback'!this.setOptions()' width 10
          option .optLaserDisplay  Anchor L+T at xmax.paraLaserTest ymin.paraLaserDisplay callback'!this.setOptions()' width 10
          toggle .tglBatchClash    Anchor L+T at x1 ymax+0.6  'Batch cloud clashing' callback |!this.batchClashCallback(|
        exit

        --Define a Clash options frame
        frame .frmPresentation 'Presentation' at x1 ymax+0.25 width.frmClashOptions

          toggle .tglPresentGroup         at x1 ymax Anchor L+T 'Group Clash / Obstruction' callback '!this.groupOptionCallback()'
          toggle .tglPresentClashItem     at x1 ymax Anchor L+T 'Clash Item Aid'         callback '!this.tglPresentClashItemA.val = !this.tglPresentClashItem.val
          !this.netAfterSelectChangeCallback(!this.dbCtrl.getSelectedRows())'
          toggle .tglPresentObstruction   at x1 ymax Anchor L+T 'Clash Obstruction Aid'  callback '!this.tglPresentObstructionA.val = !this.tglPresentObstruction.val
          !this.netAfterSelectChangeCallback(!this.dbCtrl.getSelectedRows())'
          toggle .tglPresentClashPosition at x1 ymax Anchor L+T 'Clash Position Aid'     callback '!this.tglPresentClashPositionA.val = !this.tglPresentClashPosition.val
          !this.netAfterSelectChangeCallback(!this.dbCtrl.getSelectedRows())'
          toggle .tglPresentRepreObst     at x1 ymax Anchor L+T 'Obstruction Visibility' callback '!this.netAfterSelectChangeCallback(!this.dbCtrl.getSelectedRows())'
          --                 toggle .tglPresentCapping       at x1 ymax Anchor L+T 'Capping'                callback '!this.netAfterSelectChangeCallback(!this.dbCtrl.getSelectedRows())'

        exit

        --Define a Clash colours frame
        frame .frmClashColours 'Clash colours'  at xmax.frmTolerances+1 ymin.frmTolerances width 31

          para   .parMci Anchor L+T  at x1 y0.3  text 'Major clash items' width 14
          para   .parObi Anchor L+T  at xmin ymax+.4  text 'Obstruction items' width 14
          para   .parViewColour Anchor L+T  at xmin ymax+.4  text 'View Background' width 14
          button .btnMci Anchor L+T  at xmax.parMci ymin.parMci '' callback |!!colourSelectLoad('!!avaclasherui.setColorOptions(1)', 'Major clash items Colour', !!avaclasherui.btnMci.background)| width 2
          button .btnObi Anchor L+T  at xmax.parObi ymin.parObi '' callback |!!colourSelectLoad('!!avaclasherui.setColorOptions(2)', 'Minor clash items Colour', !!avaclasherui.btnObi.background)| width 2
          button .btnViewColour Anchor L+T  at xmax.parViewColour ymin.parViewColour '' callback |!!colourSelectLoad('!!avaclasherui.setColorOptions(3)', 'View Background Colour', !!avaclasherui.btnViewColour.background)| width 2
          para   .parMcC Anchor L+T  at xmax.btnMci + 1 ymin.parMci text '' width 9
          para   .parObC Anchor L+T  at xmax.btnObi + 1 ymin.parObi text '' width 9
          para   .parViewColourName Anchor L+T  at xmax.btnViewColour + 1 ymin.btnViewColour text '' width 9

        exit

        --Define a clash ignored within frame
        frame .frmClashIgnored 'Clashes Ignored Within' at xmax.frmClashOptions+1 ymax+0.25 width.frmClashColours

          toggle .tglPipe   at xmin.frmClashIgnored + 4           'PIPE'   tooltip 'Pipe'    callback '!this.setIgnored()'
          toggle .tglBran   at xmin ymax                          'BRAN'   tooltip 'Branch'    callback '!this.setIgnored()'
          toggle .tglPtr    at xmin ymax                          'PTRA'   tooltip 'Pipe Track'    callback '!this.setIgnored()'
          toggle .tglHang   at xmin ymax                          'HANG'   tooltip 'Hanger'    callback '!this.setIgnored()'
          toggle .tglRestr  at xmin ymax                          'SUPPO'  tooltip 'Support'    callback '!this.setIgnored()'
          toggle .tglEqu    at xmin ymax                          'EQUI'   tooltip 'Equipment'    callback '!this.setIgnored()'
          toggle .tglTmpl   at xmin ymax                          'TMPL'   tooltip 'Template'    callback '!this.setIgnored()'
          toggle .tglCwBran at xmin ymax                          'CWBRAN' tooltip 'Cableway Branch'    callback '!this.setIgnored()'
          toggle .tglSite   at xmin ymax                          'SITE'   tooltip 'Site'    callback '!this.setIgnored()'
          toggle .tglZone   at xmin ymax                          'ZONE'   tooltip 'Zone'    callback '!this.setIgnored()'
          toggle .tglConvey at xmin ymax                          'CONVEY' tooltip 'Conveyor'    callback '!this.setIgnored()'
          toggle .tglHVAC   at xmin ymax                          'HVAC'   tooltip 'HVAC'    callback '!this.setIgnored()'
          toggle .tglCSURPX at xmin ymax                          'CPANEL' tooltip 'Curved Surface Panel (CPANEL & CSURPX)'    callback '!this.setIgnored()'
          toggle .tglHPanel at xmin ymax                          'HPANEL' tooltip 'Hull Panel'    callback '!this.setIgnored()'

          toggle .tglStr    at xmax.tglPipe + 8 ymin.tglPipe      'STRU'   tooltip 'Structure'    callback '!this.setIgnored()'
          toggle .tglSubs   at xmin ymax                          'SUBS'   tooltip 'Sub-Structure'    callback '!this.setIgnored()'
          toggle .tglFrmw   at xmin ymax                          'FRMW'   tooltip 'Framework'    callback '!this.setIgnored()'
          toggle .tglSbfrm  at xmin ymax                          'SBFR'   tooltip 'Sub-Frame'    callback '!this.setIgnored()'
          toggle .tglHandra at xmin ymax                          'HANDRA' tooltip 'Handrail'    callback '!this.setIgnored()'
          toggle .tglStrflt at xmin ymax                          'STRFLT' tooltip 'Stair Flight'    callback '!this.setIgnored()'
          toggle .tglRladdr at xmin ymax                          'RLADDR' tooltip 'Rung Ladder'    callback '!this.setIgnored()'
          toggle .tglSctn   at xmin ymax                          'SCTN'   tooltip 'Section'    callback '!this.setIgnored()'
          toggle .tglGensec at xmin ymax                          'GENSEC' tooltip 'General Section'  callback '!this.setIgnored()'
          toggle .tglPcoj   at xmin ymax                          'PCOJ'   tooltip 'Primary Compound Joint'    callback '!this.setIgnored()'
          toggle .tglSladdr at xmin ymax                          'SLADDR' tooltip 'Step Ladder'    callback '!this.setIgnored()'
          toggle .tglPltfrm at xmin ymax                          'PLTFRM' tooltip 'Platform'    callback '!this.setIgnored()'
          toggle .tglUPanel at xmin ymax                          'UPANEL' tooltip 'Unified Panel'    callback '!this.setIgnored()'
        exit

        frame .frmSaveRestoreSystem 'Save / Restore' at x1 ymax.frmPresentation+2 width 62
          button .btnRestore      'Reset System Defaults'  Anchor T+L callback '!this.restoreSavedOptions(|NORMAL|, |AVEVA_DESIGN_DFLTS|, true)' at x0.5 ymax
          para   .parSaveRestoreUser at xmax+6 ymin  text 'User Settings:' width 13
          button .btnSave         'Save' Anchor T+L callback '!this.saveOptions()' at xmax ymin width 7
          button .btnRestoreSaved 'Restore' Anchor T+L callback '!this.restoreSavedOptions(|NORMAL|, |AVEVA_DESIGN_USER|, true)' at xmax+1 ymin width 7
        exit

      exit

      --Define the Report frame
      frame .frmReport 'Report'  at x0 y0

        -- Save report to file?
        toggle .tglRepSave at x1 y0.5 'Report to file when checking for clashes' callback '!this.activeInactiveReportOptions()'

        --Define a Report Options frame

        -- Position
        frame .frmPos 'Position' at x1 ymax+0.5 width 39
          rtoggle .tglPosWrld 'World' at x1 y1 callback '!this.setReportOptions()' tagwidth 10
          rtoggle .tglPosSt   'Site'  at xmax ymin callback '!this.setReportOptions()' tagwidth 10
          rtoggle .tglPosOff  'Off'   at xmax ymin   callback '!this.setReportOptions()' tagwidth 10
        exit

        -- Duplicate
        frame .frmDup 'Duplicate'  at x1 ymax+0.2 width 39
          rtoggle .tglDupFst 'First' at x1 y1  callback '!this.setReportOptions()' tagwidth 10
          rtoggle .tglDupSnd 'Second' at xmax ymin  callback '!this.setReportOptions()' tagwidth 10
          rtoggle .tglDupBth 'Both'   at xmax ymin  callback '!this.setReportOptions()' tagwidth 10
        exit

        -- Levels
        frame .frmLvl 'Levels' at x1 ymax+0.2 width 39
          toggle .tglLvlCls 'Clashes'    at x1 y1   callback '!this.setReportOptions()' tagwidth 10
          toggle .tglLvlClr 'Clearances'    at xmax y1 callback '!this.setReportOptions()' tagwidth 10
          toggle .tglLvlTch 'Touches' at xmax y1 callback '!this.setReportOptions()' tagwidth 10
        exit

        --Significant options frame
        frame .frmSigOption 'Listing' at xmax+1 y2 width 22
          toggle .tglSigOn tagwidth 13 'List elements'   callback '!this.setReportOptions()'
          list .lstSignificant Anchor L+R+T   callback '!this.setSections()' columns single zerosel width 16.5 height 14
        exit

        -- Report format
        frame .frmObstr 'Report format' at x1 ymax.frmLvl+0.2 width 39
          --toggle .tglApprOn    at ymin + 1.2  'Approved'     callback '!this.setReportOptions()'
          toggle .tglHeadOn    at xmin.frmObstr+1 y1      'Header'      callback '!this.setReportOptions()'
          toggle .tglMainOn    at xmin.frmObstr + 13 y1   'Main Body'   callback '!this.setReportOptions()'
          toggle .tglNmbOn     at xmin.frmObstr + 25 y1   'Numbering'   callback '!this.setReportOptions()'
          toggle .tglPrmOn     at xmin.frmObstr+1  ymax   'Primary'     callback '!this.setReportOptions()'
          toggle .tglObstrOn   at xmin.frmObstr + 13 ymin 'Obstruction' callback '!this.setReportOptions()'
          toggle .tglRefOn     at xmin.frmObstr + 25 ymin 'Reference'   callback '!this.setReportOptions()'
          toggle .tglSmmrOn    at xmin.frmObstr+1  ymax   'Summary'     callback '!this.setReportOptions()'
        exit

        --Report to file option
        frame .frmRepExp 'Report to file' at x1 ymax+0.5 width 62
          -- Set report fileName
          text .txtFile at x1 y1 'File name' width 35 is STRING
          !this.txtFile.val = '%AVEVA_DESIGN_USER%/MyReport.txt'
          button .browser 'Browse...' at xmax+1.5 ymin callback '!this.fileBrowserLoad()'
        exit

        frame .frmSaveRestoreSystemReport 'Save / Restore' at x1 ymax+1 width 62
          button .btnRestoreReport      'Reset System Defaults'  Anchor T+L callback '!this.restoreSavedOptions(|REPORT|, |AVEVA_DESIGN_DFLTS|, true)' at x0.5 ymax
          para   .parSaveRestoreUserRreport at xmax+6 ymin  text 'User Settings:' width 13
          button .btnSaveReport         'Save' Anchor T+L callback '!this.saveReportOptions()' at xmax ymin width 7
          button .btnRestoreSavedReport 'Restore' Anchor T+L callback '!this.restoreSavedOptions(|REPORT|, |AVEVA_DESIGN_USER|, true)' at xmax+1 ymin width 7
        exit

      exit

    exit
    menu .popmenumain
    !this.popmenumain.add('callback', 'Print Preview', '!this.dbCtrl.printpreview()' )
    !this.popmenumain.add('callback', 'Save to Excel...', '!this.saveMain(!!avaclasherui.fileName())')

    -- ------------ Clash View ------------
    --Clipping options
    --        frame .frmClipping 'Clipping' at xmax+2 ymin.btnRefresh Anchor T+L+R width to max.selectedParagraph
    --           toggle .tglClip 'Clip Box'    callback '!this.clipClash()'
    --           path right
    --           text   .txtClip '' callback '!this.clipClash()' Anchor T+L+R width to max.frmClipping-1 is REAL format !!distanceFmt
    --           var !units split units
    --           if (!units[3] eq 'MM') then
    --             slider .clipSlider horizontal at xmin ymax Anchor T+L+R callback '!this.sliderCallback('range -5000 +5000 step 100 val 0 width.txtClip
    --             !this.txtClip.val = 2000mm
    --           else
    --             slider .clipSlider horizontal at xmin ymax Anchor T+L+R callback '!this.sliderCallback('range -200 +200 step 4 val 0 width.txtClip
    --             !this.txtClip.val = 72in
    --           endif
    --        exit

    path down

    !localLimits = 's5000mm w5000mm d5000mm to n5000mm e5000mm u5000mm'

    view .view at xmax+2 ymin.btnRefresh givolume
      shading on
      limits auto
      setcolour 15
      sethighlight   10
      limits local $!localLimits

      -- Input Modes
      -- Standard Element Pick
      inmode create _cie       type |DES_PICK_CIE|
      -- Navigate
      inmode create _navi       type |DES_NAVIGATE|
      -- Standard Element Pick
      inmode create _pick       type |DES_PICK|
      -- Pick Any (Element, Ppoint, Pline)
      inmode create _pAny       type |DES_PICK_ANY|
      -- Plines
      inmode create _pLine      type |DES_PICK_PLINE|
      -- Ppoints
      inmode create _point      type |DES_PICK_POINT|
      -- Screen Position
      inmode create _screen     type |DES_3D_LINE|
      -- Laser Model rays
      inmode create _pickXGeom  type |DES_PICK_XGEOM|
      -- Default (Navigation)
      inmode create _pickDetail type |DES_PICK_DETAIL|
      -- Default (Navigation)
      inmode create _default    type |DES_PICK_CIE|

    exit

    -- Set Defaults for Modes
    !this.view.cie.cursor     = 'Pointer'
    !this.view.cie.prompt     = 'CIE : '

    !this.view.navi.cursor     = 'Pointer'
    !this.view.navi.prompt     = 'Navigate : '

    !this.view.pick.cursor     = 'Pointer'
    !this.view.pick.prompt     = 'Pick Element : '

    !this.view.pAny.cursor     = 'Pointer'
    !this.view.pAny.prompt     = 'Pick Any : '

    !this.view.pLine.cursor    = 'Pointer'
    !this.view.pLine.prompt    = 'Pick Pline : '

    !this.view.point.cursor    = 'Pick'
    !this.view.point.prompt    = 'Point Ppoint : '

    !this.view.screen.cursor   = 'Crosshair'
    !this.view.screen.prompt   = 'Pick 3D Position : '

    !this.view.default.cursor  = 'Pointer'
    !this.view.default.prompt  = 'CIE : '

    --Members
    -- Marine or plant project
    member .marine             is BOOLEAN

    using namespace 'Aveva.Core.Presentation'
    member .fromPosControl     is POSITIONCONTROL
    member .toPosControl       is POSITIONCONTROL

    -- Store Positions
    member .storedFromPosition is POSITION
    member .storedToPosition   is POSITION

    -- Checked element
    member .checkedElement is DBREF

    -- Checked support
    member .supportMem   is ARRAY

    -- NetGridControl
    member .dbCtrl is NETGRIDCONTROL

    -- ARRAY of clashes
    member .clashes is ARRAY

    -- list of obstructions (DBREF array)
    member .obstructionList is ARRAY

    -- list of exclusions (DBREF array)
    member .exclusionList is ARRAY

    -- collection of graphically picked elements
    member .pickList is ARRAY

    -- clasher instance
    member .clasher is AVACLASHER

    -- Clip Data
    member .clipBox    is GPHCLIPBOX
    member .clipPlanes is ARRAY
    member .memoryBox  is REAL

    -- Form Information
    member .type     is STRING
    member .number   is REAL

    -- Aid Graphics
    member .limitsAid   is REAL
    member .clashAid    is REAL

    -- last selected clash items (to reset highlighting)
    member .lastClashItem       is DBREF
    member .lastObstructionItem is DBREF
    member .lastClashTube       is BOOLEAN
    member .lastObstructionTube is BOOLEAN

    -- Remember the last settings on form quit
    member .touchesGadget              is STRING
    member .checkWithinBranchGadget    is STRING
    member .connectionsGadget          is STRING

    member .cloudDataExists is BOOLEAN
    member .userModifiedBatchMode is BOOLEAN

    --End of form definition

  endif

exit

-- Constructor and Initialization

------------------------------------------------------------------------
--
-- Method:      avaclasherui
--
-- Description: Constructor
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .avaclasherui()

  -- !mm = object AVEVAMODULEMANAGER()
  -- !this.marine = !mm.currentProductName().upcase().eq('HULL & OUTFITTING')
  !this.marine = ( !!module().projectType.upcase() eq 'MARINE' )

  --make sure avaclasherui can be used only in Design
  if (!!cdcnmod eq 'DESIGN') then

    using namespace 'Aveva.Core.Presentation'

    -- create instance of .net control
    !this.dbCtrl = object NETGRIDCONTROL()

    -- add PML event handlers to .net control
    !this.dbCtrl.addEventHandler('OnPopup',           !this, 'netPopupMainCallback')
    !this.dbCtrl.addEventHandler('AfterSelectChange', !this, 'netAfterSelectChangeCallback')

    -- add .net control to PML container
    !this.netFrame.control = !this.dbCtrl.handle()

    -- single row selection
    !this.dbCtrl.singleRowSelection(TRUE)

    -- Initialise 3D view gadget
    !this.view.step = 25mm

    -- Initialise Form Data
    !formName        = !!avaclasherui
    !formName.type   = 'Design'
    !formName.number = 100

    -- !this.prompt.background = !this.background

    -- Assign defaults clipbox and clip planes
    !formName.clipBox.gphClipbox(!formName.view)
    !formName.clipPlanes.clear()
    do !i to 6
      !formName.clipPlanes.append(object GPHCLIPPLANE(!formName.view, !i))
    enddo

    -- Initiate pick list
    !this.pickList = ARRAY()

    --Populate column list

    !this.lstObst.setHeadings(split('Number,Name',','))
    !this.lstExcl.setHeadings(split('Number,Name',','))
    !this.lstSignificant.setHeadings(split('Type,Check',','))

    --Control functions for obstruction / exclusion lists
    !this.displayObst()
    !this.displayExcl()
    !this.buttonInitControl()

    --Fill the pulldown gadgets
    !this.optNav.dtext  = split('Clash Item,Obstruction',',')
    !this.optNav.rtext  = split('ITEM,OBST',',')
    !this.optNav.active = !this.togNav.val

    --Fill the pulldown gadgets
    !this.optTch.dtext = split('included,ignored',',')
    !this.optTch.rtext = split('TRUE,FALSE',',')

    --Fill the pulldown gadgets
    !this.optLaserTest.dtext = split('Cell,Exact', ',')
    !this.optLaserTest.rtext = split('LMI TEST CELLS,LMI TEST EXACT', ',')
    !this.optLaserTest.select(|RTEXT|, |LMI TEST EXACT|)

    --Fill the pulldown gadgets
    !this.optLaserDisplay.dtext = split('Cell,Exact', ',')
    !this.optLaserDisplay.rtext = split('LMI DISPLAY CELLS,LMI DISPLAY EXACT', ',')
    !this.optLaserDisplay.select(|RTEXT|, |LMI DISPLAY CELLS|)

    --Fill the pulldown gadgets
    !this.optCwb.dtext = split('are included,ignore adjacent,are ignored',',')
    !this.optCwb.rtext = split('ACHECK,BCHECK,NOCHECK',',')

    --Fill the pulldown gadgets
    !this.optCon.dtext = split('are included,are ignored,with spec are ignored',',')
    !this.optCon.rtext = split('INCLUDE CONNECTIONS,IGNORE CONNECTIONS,IGNORE CONNECTIONS WITH SPECIFICATION',',')

    --Fill the pulldown gadgets
    !this.optObstAdd.dtext = split('Current Element,Pick Element,Current Selection,Current Collection,Point Cloud models in display,All',',')
    !this.optObstAdd.rtext = split('Explorer,Picked,Selection,List,Laser,All',',')

    --Fill the pulldown gadgets
    !this.optExclAdd.dtext = split('Current Element,Pick Element,Current Selection,Current Collection',',')
    !this.optExclAdd.rtext = split('Explorer,Picked,Selection,List',',')

    --Fill the pulldown gadgets
    !this.optLimitsSet.dtext = split('Current Element,Picked Elements,Defined by 2 Picks,Current Selection,Current Collection',',')
    !this.optLimitsSet.rtext = split('Explorer,Picked,Origins,Selection,List',',')

    -------------------- Setup for position control ----------------------
    !this.storedFromPosition = object POSITION('E0')
    !this.storedToPosition   = object POSITION('E0')
    !this.togLimitsAids.val = true

    -- Declare namespace where position control exists
    using namespace 'Aveva.Core.Presentation'

    -- Create new instance of the position control
    !this.fromPosControl  = object POSITIONCONTROL()
    !this.toPosControl    = object POSITIONCONTROL()

    !this.fromPosControl.setAidNumber(!!aidNumbers.add('WRTAxis AvaClasherUI From'))
    !this.toPosControl.setAidNumber(!!aidNumbers.add('WRTAxis AvaClasherUI To'))

    -- Initialise
    !this.fromPosControl.setUpPositionControl()
    !this.toPosControl.setUpPositionControl()

    -- Aid graphic numbers
    !this.limitsAid            = !!aidNumbers.add('Clasher Limits Aids')
    !this.clashAid             = !!aidNumbers.add('Clash Aids')
    !this.tglPresentClashItem.val     = true
    !this.tglPresentObstruction.val   = true
    !this.tglPresentClashPosition.val = true
    !this.tglPresentClashItemA.val     = true
    !this.tglPresentObstructionA.val   = true
    !this.tglPresentClashPositionA.val = true
    --    !this.tglPresentCapping.val       = true

    -- Error handle
    !this.fromPositionContainer.control = !this.fromPosControl.handle()
    !this.toPositionContainer.control = !this.toPosControl.handle()

    -- Whenever the posControl gadget changes
    !this.fromPosControl.changeAction(|!!avaclasherui.posControl()|)
    !this.toPosControl.changeAction(|!!avaclasherui.posControl()|)

    !this.fromPosControl.pickAction(|Generic|)
    !this.toPosControl.pickAction(|Generic|)

    --Set default options for clipping
    --    !this.tglClip.val = false

    !this.tglSigOn.setTooltip('Lists all significant elements which have been checked, not just those for which clashes have been detected.')

    -- Run the defaults
    !this.restoreDefaults()

    -- Temporarily inactive Report Position Site
    if (!this.marine) then
      !this.tglPosSt.active = false
    endif
    -- Some options not required in Plant
    if (!this.marine.not()) then
      !this.tglCSURPX.visible = false
      !this.tglHPanel.visible = false
      !this.tglPltfrm.visible = false
      !this.tglUPanel.visible = false
    endif

    !this.frmObstructions.callback = '!this.tabsetCallback('

    !this.cloudDataExists = false
  endif
 
endmethod

------------------------------------------------------------------------
--
-- Method:      firstShown
--
-- Description: Method run when form is first shown
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .firstShown()

  -- Add into edg system
  !!edgCntrl.addView(!this.view)
  -- Set defaults
  !viewProperties = object GPHVIEWOPT()
  !viewProperties.setShadows(false)
  !viewProperties.setTranslucentEdges(true)
  --   !viewProperties.showEditMode    = false
  --   !viewProperties.showCommandLine = false
  !viewProperties.applyToView(!this.view)
  !this.clipBox.capon()

  !this.formTitle     = 'Clashes'

  !this.parClash.val = !!ce.name
  !this.parSupportSelected.val = ''

  --   !this.memoryBox = !this.txtClip.val

  -- View Background colour
  !this.btnViewColour.background = !this.view.background
  !this.parViewColourName.val    = !!colourName(!this.btnViewColour.background.real())

  -- Persist any User settings
  !this.restoreSavedOptions(|NORMAL|, |AVEVA_DESIGN_USER|, false)
  !this.restoreSavedOptions(|REPORT|, |AVEVA_DESIGN_USER|, false)

endmethod

------------------------------------------------------------------------
--
-- Method:      Init
--
-- Description: Initialise
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .init()

  -- Registering the PositionControl gadgets means they update whenever the global coordinate format changes.
  !!coordinateFMT.registerDependant('!!avaclasherui.toPosControl')
  !!coordinateFMT.registerDependant('!!avaclasherui.fromPosControl')

  if (!!cdcnmod neq 'DESIGN') then

    !this.btnNotDesign.setFocus()

  else

    -- clear last clash items
    !this.lastClashItem       = object DBREF()
    !this.lastObstructionItem = object DBREF()
    !this.lastClashTube       = false
    !this.lastObstructionTube = false

    --Create significant list
    !col = split('BRAN;EQUI;FRMW;HANG;PIPE;PTRA;SUPP;SBFR;SITE;STRU;SUBE;SUBS;ZONE',';')
    do !index indices !col
      !dtext[!index][1] = !col[!index]
      !dtext[!index][2] = 'OFF'
    enddo

    !this.lstSignificant.setRows(!dtext)

    --Load default settings
    !this.getOptions()
    $!this.touchesGadget
    handle ANY
      -- First time will be unset
    endhandle
    $!this.checkWithinBranchGadget
    handle ANY
      -- First time will be unset
    endhandle
    $!this.connectionsGadget
    handle ANY
      -- First time will be unset
    endhandle

    -- set obstruction toggle to current core value
    VAR !coreRepreObst REPRESENTATION OBSTRUCTION
    !this.tglPresentRepreObst.val = !coreRepreObst.upcase().eq('ON')

    --Enter DESCLASH mode
    !this.clasher.start()

    -- Turn ON graphical feedback
    !this.clasher.reportSettingsSet('GRAPHICS',TRUE)
    !this.clasher.reportSettingsSet('PRIMARY', (!this.tglRepSave.val AND !this.tglPrmOn.val))

    --Setting the clash override option
    !this.clasher.overrideSet(TRUE)

    -- I need to check with Gordon what the out command does, but it is important
    !this.clasher.command('OUT')
    handle ANY
    endhandle

    !this.cloudDataExists = !!modelContainsCloudPointClouds()
    !this.updateBatchClashOption()

    --Exit DESCLASH mode
    !this.clasher.end()

    !this.activeInactiveReportOptions()

    --      !this.activeInactiveClipOptions()
  endif

  !this.parClash.val = !this.checkedElement.name
  handle ANY
    !this.parClash.val = !!ce.name
  endhandle
  -- no support selected initially
  !this.parSupportSelected.val = ''

  !this.supportMem = object ARRAY()
  !this.btnSupportRecheck.active = false

  !this.keyboardFocus = !this.view
  handle ANY
  endhandle

endmethod


------------------------------------------------------------------------
--
-- Method:      updateBatchClashOption
--
-- Description: Update the laser batch clash toggle
--
------------------------------------------------------------------------
define method .updateBatchClashOption()

  !isBatchClashingOn = !this.isBatchClashingOn()

  if (set (!this.userModifiedBatchMode)) then
    !this.tglBatchClash.val = !this.userModifiedBatchMode or !isBatchClashingOn
  else
    !this.tglBatchClash.val = !this.cloudDataExists or !isBatchClashingOn
  endif

  -- Only enable batch clashing toggle if there is cloud data
  !this.tglBatchClash.active = !this.cloudDataExists and not !isBatchClashingOn

  endmethod

------------------------------------------------------------------------
--
-- Method:      .batchClashCallback
--
-- Description: Callback for the  cloud batch clash toggle
--

define method .batchClashCallback(!gadget is GADGET, !action is STRING)

  !gadget.owner().userModifiedBatchMode = !action eq |SELECT|

endmethod
  
------------------------------------------------------------------------
--
-- Method:      isBatchClashingOn
--
-- Description: Determine whether batch cloud clashing has been turned on
--
------------------------------------------------------------------------
define method .isBatchClashingOn() is BOOLEAN

  var !batch clash lmi batch
  !value = !batch.after(':').trim()  
  return  !value.eq('OFF').not()

endmethod

------------------------------------------------------------------------
--
-- Method:      tabsetCallback
--
-- Description: Method invoked when tab in tabset is selected
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .tabsetCallback(!gadget     is   ANY, $
  !action     is   STRING)

  -- Refresh the obstruction list when the tab is made current
  if ((!gadget eq !this.frmObstructions) and (!action eq 'SHOWN')) then
    --Control functions for obstruction / exclusion lists
    !this.displayObst()
    !this.displayExcl()
    !this.buttonInitControl()

  endif

endmethod

-- Main

------------------------------------------------------------------------
--
-- Method:      Check
--
-- Description: Check clashes for current element and displays them in the clash list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     DBREF       Element to be Clash Checked
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .check(!element is DBREF)

  !elements = object ARRAY()
  !elements[1] = !element
  !this.check(!elements)

endmethod

define method .check(!elements is ARRAY)

  !this.findClashes(!elements)
  !this.showClashes(!elements.first())

endmethod

------------------------------------------------------------------------
--
-- Method:      findClashes
--
-- Description: Find clashes for element and displays them in the clash list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     DBREF       Element to be Clash Checked
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .findClashes(!elements is ARRAY)

  do !element value !elements

    -- Validate the check element
    if (!element.set() and !element.dbType eq 'DESI') then
      -- this is OK
      !this.checkedElement = !element
    else
      -- this is not OK
      !!alert.error('Invalid element to Clash Check')
      return
    endif
  enddo

  -- Validate the obstruction elements
  if (!this.obstructionList.size() gt 0) then
    -- this is OK
  else
    -- this is not OK
    !!alert.error('Invalid obstruction')
    return
  endif

  -- Spatial Map OK warning
  var !mapOK MAPOK
  if (!mapOK.boolean().not()) then
    -- this may be OK but give a warning
    !!alert.warning('The Spatial Map may need rebuilding. Please inform your System Administrator')
  endif

  -- Set the new options
  !this.setOptions()
  !this.setReportOptions()

  -- Set the batch clashing option
  !isBatchClashingOn = !this.isBatchClashingOn()
  if (!this.cloudDataExists and !isBatchClashingOn.not() and !this.tglBatchClash.val) then
    -- Set batch cloud clash mode if required
    !this.clasher.start()
    !this.clasher.command('LMI BATCH ON') 
    !this.clasher.end()
  endif
  !this.updateBatchClashOption()

  -- Check if the results should be saved to file
  if (!this.tglRepSave.val) then
    !fileName = '"' & !this.txtFile.val & '"'

    if (!this.txtFile.val eq '') then
      !fileName = !!alert.warning('Input report file name')
      !this.frmReport.selected = TRUE
      !this.txtFile.setFocus()
      return
    endif

    -- Set report output to file
    alpha file $!fileName overwrite
    handle ANY
      !!alert.error('Unable to write report file')
    endhandle

    -- If not writing to file suppress Primary reporting as this
    -- can effect feedback on laser data clashes
  else
    !this.clasher.start()
    !this.clasher.reportSettingsSet('PRIMARY', (!this.tglRepSave.val AND !this.tglPrmOn.val))
    !this.clasher.end()
  endif

  clock init
  --Set the name of CE as the checked item
  !this.parClash.val = !elements[1].fullname
  handle ANY
    !this.parClash.val = !!ce.name
  endhandle

  --Hide the form
  !!cadcSYS.hide()

  --Open the channel
  !!cadcSYS.cadcCOM.channel = 'RQUEST'

  if (!elements.set() and !elements.size() gt 0) then
    --Check the CE
    !this.clasher.start()
    !this.clasher.check(!elements)
    !this.clasher.end()
    clock read elapsed
  endif


  --Open the channel
  !!cadcBTH.cadcCOM.channel = 'RQUEST'

  --Turn off the export to file
  if (!this.tglRepSave.val) then
    alpha file end
    handle ANY
      -- In case the file did not open
    endhandle

    -- If not writing to file reset Primary reporting as this
    -- can effect feedback on laser data clashes
  else
    !this.clasher.start()
    !this.clasher.reportSettingsSet('PRIMARY', (!this.tglRepSave.val AND !this.tglPrmOn.val))
    !this.clasher.end()
  endif

  --Load the clashes in the form
  !this.getResults()

endmethod

------------------------------------------------------------------------
--
-- Method:      showClashes
--
-- Description: Fill grid with clashes
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1   R      DBREF       Clashed item
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .showClashes(!element is DBREF)

  --Display the clashes
  !this.displayClashes()

  --Refresh clash count
  !this.frmData.tag = 'Clashes (' + !this.clasher.clashCountGet().string() + ')'

  -- Clear the paragraph gadget
  if (!this.clasher.clashCountGet() eq 0) then
    !this.selectedParagraph.val = ''
  endif

  -- Each new check should switch clip off
  !this.clipBox.clear()
  --   !this.tglClip.val = false
  --   !this.activeInactiveClipOptions()
  !this.dbCtrl.clearRowSelection()
  !!aidClear(!this.clashAid.string(), 'ALL')
  !this.clipClash()
  --Disable the clipbox if that option is not chosen
  --   if (!this.tglClip.val.not()) then
  --     !!avaclasherui.clipBox.disable()
  --     !!avaclasherui.lClippingMenu.select('Enable', false)
  --   endif
  !!gphViews.limits(!this.view, !element)

endmethod
------------------------------------------------------------------------
--
-- Method:      GetResults
--
-- Description: Fetch all clashes from the system clasher and populate the clash list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .getResults()

  --Define variables
  !dtext  = object ARRAY()

  --Count all clashes
  !clashCount = !this.clasher.clashCountGet()

  --Loop on the total of clashes
  do !a from 1 to !clashCount

    --Get the details of the Clash from the system
    !tempClash = object AVACLASH(!a)

    --Get the clash number, padded it so it will sort
    if     (!a lt 10)  then
      !dtext[!a][1] = '  ' & !a.string()
    elseif (!a lt 100) then
      !dtext[!a][1] = ' ' & !a.string()
    else
      !dtext[!a][1] = !a.string()
    endif

    --Get the clash
    !dtext[!a][2] = !tempClash.clashType
    !dtext[!a][3] = !tempClash.clashExtent

    --Get the clash items
    !dtext[!a][4] = !tempClash.clasherType
    !dtext[!a][5] = !tempClash.clasheeType

    --Get items types
    -- Clasher Type
    !dbrefClasher     = object DBREF(!tempClash.clasherType)
    handle any
      -- Must be Tubing
      !tubeTest = (!tempClash.clasherType.before(' (tube)'))
      var !tube IL TUB of $!tubeTest
      !dbrefClasher = object DBREF(!tube)
    endhandle
    !majorType = !dbrefClasher.type
    handle any
      -- I cannot see that we need this
      !majorType = 'ERROR'
    endhandle

    -- Clashee Type
    !dbrefClashee     = object DBREF(!tempClash.clasheeType)
    handle any
      -- Must be Tubing
      !tubeTest = (!tempClash.clasheeType.before(' (tube)'))
      var !tube IL TUB of $!tubeTest
      !dbrefClashee = object DBREF(!tube)
    endhandle
    !obstType = !dbrefClashee.type
    handle any
      -- I cannot see that we need this
      !obstType = 'ERROR'
    endhandle

    !dtext[!a][6]  = !majorType&'/'&!obstType

    --Get the clash position
    !dtext[!a][7]  = !tempClash.clashPosition.east.int().string()
    !dtext[!a][8]  = !tempClash.clashPosition.north.int().string()
    !dtext[!a][9]  = !tempClash.clashPosition.up.int().string()
    !dtext[!a][10] = !tempClash.clashPosition.east.int().string(!!distanceFmt)
    !dtext[!a][11] = !tempClash.clashPosition.north.int().string(!!distanceFmt)
    !dtext[!a][12] = !tempClash.clashPosition.up.int().string(!!distanceFmt)

    -- Add a Primary Item so using .net grid we can group the clashes by the Primary Item (Say a branch or equipment for example)
    !dtext[!a][13] = !dbrefClasher.prmown.namn
    !dtext[!a][14] = !dbrefClashee.prmown.namn

    -- Store the clash/obstruction items dbref for navigation function on grid
    !dtext[!a][15] = !dbrefClasher.string().replace('IL TUB OF','')
    !dtext[!a][16] = !dbrefClashee.string().replace('IL TUB OF','')


    -- Add Ship reference column
    if( !this.marine ) then
      !pos         = !tempClash.clashPosition
      !argument[1] = !pos
      !shipX = !!ce.attribute('shipX', !argument)
      handle any
        !dtext[!a][17] = 'unset'
      elsehandle none
        !shipY = !!ce.attribute('shipY', !argument)
        !shipZ = !!ce.attribute('shipZ', !argument)
        !dtext[!a][17] = !shipX + ' ' + !shipY + ' ' + !shipZ
      endhandle
    endif

    -- Reset the fullname instead of refs
    if (!tempClash.clasherType.before(' (tube)') eq !tempClash.clasherType) then
      !dtext[!a][4] = !tempClash.clasherType.before(' (tube)').dbref().fullname
    else


      !dtext[!a][4] = !tempClash.clasherType.before(' (tube)').dbref().fullname & ' (tube)'
    endif
    -- Reset the fullname instead of refs
    if (!tempClash.clasheeType.before(' (tube)') eq !tempClash.clasheeType) then
      !dtext[!a][5] = !tempClash.clasheeType.before(' (tube)').dbref().fullname
    else
      !dtext[!a][5] = !tempClash.clasheeType.before(' (tube)').dbref().fullname & ' (tube)'
    endif


  enddo

  --Fill the list
  !this.clashes = !dtext

endmethod
------------------------------------------------------------------------
--
-- Method:      DisplayClashes
--
-- Description: Control the types of shown clashes.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .displayClashes()

  --Define variables
  !dtext  = object ARRAY()
  !rtext  = object ARRAY()

  --Loop on the list of clashes
  do !a indices !this.clashes

    --If the clash is of type 'physical' (CLASH)
    if (!this.clashes[!a][3].eq('CLASH')) then
      !dtext.append(!this.clashes[!a])
      !rtext.append(!this.clashes[!a][1])
      skip
    endif

    --If the clash is of type 'touch' (TOUCH)
    if (!this.clashes[!a][3].eq('TOUCH')) then
      !dtext.append(!this.clashes[!a])
      !rtext.append(!this.clashes[!a][1])
      skip
    endif

    --If the clash is of type 'clearance' (CLEARANCE)
    if (!this.clashes[!a][3].eq('CLEARANCE')) then
      !dtext.append(!this.clashes[!a])
      !rtext.append(!this.clashes[!a][1])
    endif

    --If the clash is of type 'NOT PROVEN' (NOT PROVEN)
    if (!this.clashes[!a][3].eq('NOT PROVEN')) then
      !dtext.append(!this.clashes[!a])
      !rtext.append(!this.clashes[!a][1])
      skip
    endif

  enddo

  --Fill the list
  var !att[1] 'No'
  var !att[2] 'Clash'
  var !att[3] 'Type'
  var !att[4] 'Clash Item'
  var !att[5] 'Obstructer'
  var !att[6] 'Clashed'
  var !att[7] ' .X  '
  var !att[8] ' .Y  '
  var !att[9] ' .Z  '
  var !coord COORD
  if (!coord eq 'ENU') then
    var !att[10] ' E  '
    var !att[11] ' N  '
    var !att[12] ' U  '
  else
    var !att[10] ' X  '
    var !att[11] ' Y  '
    var !att[12] ' Z  '
  endif
  var !att[13] 'Clash'
  var !att[14] 'Obstruction'
  var !att[15] 'Clasher Item DBREF'
  var !att[16] 'Obstruction Item DBREF'
  if( !this.marine ) then
    var !att[17] 'Ship Ref'
  endif

  !title = 'Clashes'
  using namespace  'Aveva.Core.Presentation'
  !nds = object NETDATASOURCE(!title, !att, !dtext)
  !this.dbCtrl.bindToDataSource(!nds, true)
  -- Hidden columns to help with units conversion issues
  !this.dbCtrl.setColumnVisibility(7, false)
  !this.dbCtrl.setColumnVisibility(8, false)
  !this.dbCtrl.setColumnVisibility(9, false)

  -- Hide clasher/obstruction items dbref columns
  !this.dbCtrl.setColumnVisibility(15, false)
  !this.dbCtrl.setColumnVisibility(16, false)

  -- Group Clashes in the .net grid
  if (!this.tglPresentGroup.val) then
    !this.dbCtrl.setGroupByColumn(13, true)
    !this.dbCtrl.setGroupByColumn(14, true)
  else
    !this.dbCtrl.setGroupByColumn(13, false)
    !this.dbCtrl.setGroupByColumn(14, false)
  endif

  --   !this.dbCtrl.selectRow(1)
  --   handle ANY
  --     -- no clashes so clear the graphics (however this does not return an error)
  --   endhandle

  if (!this.dbCtrl.getRows().size() eq 0) then
    !!aidClear(!this.clashAid.string(), 'ALL')
  endif

  --Refresh the clip volume
  !this.clipClash()

endmethod
------------------------------------------------------------------------
--
-- Method:      ClipClash
--
-- Description: Control the display of the clashes in the 3D view, setting the clip box
--              to zero removes the limits on the clip box.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .clipClash()

  !index = object REAL()

  --Get the current user selection
  !sel = !this.dbCtrl.getSelectedRows()
  if (!sel.unset()) then
    return
  else
    !index = !sel[1][1].real()
  endif
  !selectedClash = !sel[1]

  --Quit if we have no selection
  if (!index.unset()) then
    --     !this.tglClip.active    = false
    --     !this.txtClip.active    = false
    --     !this.clipSlider.active = false
    return
    --   else
    --     !this.tglClip.active    = true
    --     !this.activeInactiveClipOptions()
  endif

  --Build a position object
  !position                 = object POSITION('E ' & !this.clashes[!index][7] & ' N ' & !this.clashes[!index][8] & ' U ' & !this.clashes[!index][9] & ' WRT WORLD')

  -- Clear the clash aid graphics only and then show them again
  !!aidClear(!this.clashAid.string(), 'ALL')

  !clashItemString = !selectedClash[15]
  !clashItem       = !clashItemString.dbref()
  handle any
    !!alert.error('The clash item has been deleted since this clash report was generated. Please run the clash check again')
    return
  endhandle
  !clashName         = !clashItem.namn
  -- Check for Tube
  !tubeClash   = (match(!selectedClash[4], ' (tube)') gt 0)
  if (!tubeClash) then
    !clashName = IL TUB of $!clashName
    handle ANY
    endhandle
  endif
  !obstructionItemString = !selectedClash[16]
  !obstructionItem   = !obstructionItemString.dbref()
  handle any
    !!alert.error('The obstruction item has been deleted since this clash report was generated. Please run the clash check again')
    return
  endhandle
  !obstructionName   = !obstructionItem.namn
  -- Check for Tube
  !tubeObstruction   = (match(!selectedClash[5], ' (tube)') gt 0)
  if (!tubeObstruction) then
    !obstructionName = IL TUB of $!obstructionName
    handle ANY
    endhandle
  endif
  !clashType         = !clashItem.type
  !obstructionType   = !obstructionItem.type
  !position          = object POSITION('E ' & !selectedClash[7] & ' N ' & !selectedClash[8] & ' U ' & !selectedClash[9] & ' WRT WORLD')
  !positionUnder1    = !position
  !positionUnder2    = !position
  !positionUnder1.up = (!positionUnder2.up - 100mm)
  !positionUnder2.up = (!positionUnder2.up - 200mm)
  if (!this.marine) then
    !positionShip    = !selectedClash[17]
  endif

  -- Set obstruction representation - has to be done here otherwise clash colours removed by REPRE UPDATE
  VAR !coreRepreObst REPRESENTATION OBSTRUCTION
  !coreObstructionOn = !coreRepreObst.upcase().eq('ON')

  -- only change obstruction setting if different from core setting - for performance reasons
  if (!this.tglPresentRepreObst.val) then
    if( !coreObstructionOn.not() ) then
      -- force obstructions on
      REPRESENTATION OBSTRUCTION ON TRANSLUCENCY 75
      REPRESENTATION PROFILE OBSTRUCTION ON TRANSLUCENCY 75 UPDATE
    endif
  else
    if( !coreObstructionOn ) then
      -- force obstructions off
      REPRESENTATION OBSTRUCTION OFF
      REPRESENTATION PROFILE OBSTRUCTION OFF UPDATE
    endif
  endif

  -- Aids
  if (!this.tglPresentClashItem.val) then
    AID TEXT NUMBER $!<this.clashAid> 'Clash Item $!clashType $!clashName' at $!positionUnder1
  endif
  if (!this.tglPresentObstruction.val) then
    AID TEXT NUMBER $!<this.clashAid> 'Obstruction $!obstructionType $!obstructionName' at $!positionUnder2
  endif
  if (!this.tglPresentClashPosition.val) then
    if (!this.marine) then
      AID TEXT NUMBER $!<this.clashAid> |Clash Position $!positionShip| at $!position
    else
      AID TEXT NUMBER $!<this.clashAid> |Clash Position $!position| at $!position
    endif
  endif

  if      (!this.clashes[!index][6].split('/')[2] eq 'XGEOM') then
    if (!tubeClash) then
      !currentElement = !!ce
      !!ce            = !clashItem
      IL TUB
      handle     ANY
        !volume      = object VOLUME(!clashItem)
      elsehandle NONE
        --IARR TUB
        var !extent wvol
        !extentList  = !extent.split()
        !start       = object POSITION('E ' & !extentList[1] & ' N ' &  !extentList[2] & ' U ' &  !extentList[3] & ' WRT WORLD')
        !end         = object POSITION('E ' & !extentList[4] & ' N ' &  !extentList[5] & ' U ' &  !extentList[6] & ' WRT WORLD')
        !volume      = object VOLUME(!start, !end)
        !!ce         = !currentElement
      endhandle
    else
      !volume         = object VOLUME(!clashItem)
    endif

    --!box               = !volume.box()
    VAR !result LMI DRIVER 'aveva' EXT 'clearHighLite'
    handle NONE
      --AID BOX NUMBER $!<this.clashAid> at $!<box.position>  XLENGTH $!<box.xLength> YLENGTH $!<box.yLength> ZLENGTH $!<box.zLength>

      !fromEast       = !volume.from.east.dbunits().value()
      !fromNorth      = !volume.from.north.dbunits().value()
      !fromUp         = !volume.from.up.dbunits().value()

      !toEast         = !volume.to.east.dbunits().value()
      !toNorth        = !volume.to.north.dbunits().value()
      !toUp           = !volume.to.up.dbunits().value()

      VAR !result LMI DRIVER 'aveva' EXT 'HLC $!fromEast $!fromNorth $!fromUp $!toEast $!toNorth $!toUp'
    elsehandle ANY
    endhandle

  elseif (!this.clashes[!index][6].split('/')[2] eq 'XCELL') then
    !xcell             = !selectedClash[5].before(' (tube)').dbref()

    VAR !result LMI DRIVER 'aveva' EXT 'clearHighLite'
    handle NONE
      AID BOX NUMBER $!<this.clashAid> at $!<xcell.position> $
      xlength $!<xcell.xlen> $
      ylength $!<xcell.ylen> $
      zlength $!<xcell.zlen>

      !volume          = object VOLUME(!xcell)

      !fromEast        = !volume.from.east.dbunits().value()
      !fromNorth       = !volume.from.north.dbunits().value()
      !fromUp          = !volume.from.up.dbunits().value()

      !toEast          = !volume.to.east.dbunits().value()
      !toNorth         = !volume.to.north.dbunits().value()
      !toUp            = !volume.to.up.dbunits().value()

      VAR !result LMI DRIVER 'aveva' EXT 'HLC $!fromEast $!fromNorth $!fromUp $!toEast $!toNorth $!toUp'
    elsehandle ANY
    endhandle
  else
    -- highlight selected clash and obstruction items (not laser)
    -- reset colours of last selected clash
    !clashColourCode = !this.btnMci.background
    !obstructionColourCode = !this.btnObi.background
    !this.highlight(!this.lastClashItem, !clashColourCode, !this.lastClashTube)
    !this.highlight(!this.lastObstructionItem, !obstructionColourCode, !this.lastObstructionTube)
    -- set selected clash colour: violet for the obstruction and a dark shade of violet for the clash item
    !clashColourCode = 236
    !obstructionColourCode = 238
    !this.highlight(!clashItem, !clashColourCode, !tubeClash)
    !this.highlight(!obstructionItem, !obstructionColourCode, !tubeObstruction)
  endif

  -- record last selected clash and obstruction so clash highlight can be reinstated
  !this.lastClashItem       = !clashItem
  !this.lastObstructionItem = !obstructionItem
  !this.lastClashTube       = !tubeClash
  !this.lastObstructionTube = !tubeObstruction

  -- View through position array always required in metric real values
  !thru[1]                  = !position.east.dbunits().value()
  !thru[2]                  = !position.north.dbunits().value()
  !thru[3]                  = !position.up.dbunits().value()

  !this.view.through        = !thru

  --Check if unlimited box size should be used (0 - yes)
  !boxSize = 2000mm
  --Build the positions
  !limits[1] =  object POSITION('E ' & (!position.east - (!boxSize / 2)) & ' N ' & (!position.north - (!boxSize / 2)) & ' U ' & (!position.up - (!boxSize / 2)) & ' WRT WORLD')
  !limits[2] =  object POSITION('E ' & (!position.east + (!boxSize / 2)) & ' N ' & (!position.north + (!boxSize / 2)) & ' U ' & (!position.up + (!boxSize / 2)) & ' WRT WORLD')

  --Create a volume object
  !volume = object VOLUME(!limits[1],!limits[2])

  --Set the limits
  !!gphViews.limits(!!avaclasherui.view,!volume)

  !this.clipBox.volume(!volume)
  -- this next line causes a crash
  !activeClipBox = !this.clipBox.active()
  !this.clipBox.set()
  !this.clipBox.active(!activeClipBox)

endmethod
------------------------------------------------------------------------
--
-- Method: Dismiss
--
-- Description: Runs when form is dismissed.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .dismiss()

  -- De-registering the PositionControl gadgets means they won't update when it's not needed.
  !!coordinateFMT.deRegisterDependant('!!avaclasherui.toPosControl')
  !!coordinateFMT.deRegisterDependant('!!avaclasherui.fromPosControl')

  !this.fromPosControl.removeAllAids()
  !this.toPosControl.removeAllAids()

  -- Remove aids
  !!aidClear(!this.limitsAid.string(), 'ALL')
  !!aidClear(!this.clashAid.string(), 'ALL')

  -- Remove any EDG packets
  !!edgCntrl.remove('Clasher - Pick First Clash Limit')
  !!edgCntrl.remove('Clasher - Pick Second Clash Limit')
  !!edgCntrl.remove('Clasher - Pick Element for enclosing box')
  !!edgCntrl.remove('Clasher - Pick Element')

  -- Reset removes graphical highlighting from all Volume views
  !this.clasher.start()
  !this.clasher.command('RESET')
  !this.clasher.end()
  -- clear any clipping
  !this.clipBox.clear()

  -- We need to store these because the core DESCLASH does cannot query them
  -- Set check options (Touches ignored included ...)
  if (!this.optTch.selection('RTEXT') eq 'TRUE') then
    !this.touchesGadget = '!this.optTch.select(|RTEXT|,|TRUE|)'
  else
    !this.touchesGadget = '!this.optTch.select(|RTEXT|,|FALSE|)'
  endif

  --Set pipe check mode
  if (!this.optCwb.selection('RTEXT') eq 'ACHECK') then
    !this.checkWithinBranchGadget = '!this.optCwb.select(|RTEXT|,|ACHECK|)'
  elseif (!this.optCwb.selection('RTEXT') eq 'BCHECK') then
    !this.checkWithinBranchGadget = '!this.optCwb.select(|RTEXT|,|BCHECK|)'
  else
    !this.checkWithinBranchGadget = '!this.optCwb.select(|RTEXT|,|NOCHECK|)'
  endif

  --Set connections check mode
  if (!this.optCon.selection('RTEXT') eq 'INCLUDE CONNECTIONS') then
    !this.connectionsGadget   = '!this.optCon.select(|RTEXT|,|INCLUDE CONNECTIONS|)'
  elseif (!this.optCon.selection('RTEXT') eq 'IGNORE CONNECTIONS') then
    !this.connectionsGadget   = '!this.optCon.select(|RTEXT|,|IGNORE CONNECTIONS|)'
  else
    !this.connectionsGadget   = '!this.optCon.select(|RTEXT|,|WITHSPEC|)'
  endif

  -- reset obstruction settings to current system values
  !repreObstructionState = !!gphRepopt.obstruction()
  !repreObstructionValue = !!gphRepopt.obstructionTrans()
  if( !repreObstructionValue.set() ) then
    !!gphRepopt.obstructionTrans(!repreObstructionValue)
    handle any
    endhandle
  endif
  -- if current core obstruction state is not the same as the recorded state, then switch back to the recorded state
  VAR !coreRepreObst REPRESENTATION OBSTRUCTION
  !coreObstructionOn = !coreRepreObst.upcase().eq('ON')
  if( !repreObstructionState.neq(!coreObstructionOn) ) then
    !!gphRepopt.obstruction(!repreObstructionState)
    handle any
    endhandle
    !!gphRepopt.update()
  endif

  -- & reset profile obstruction settings to current system values
  !repreObstructionState = !!gphRepopt.profileObst()
  !repreObstructionValue = !!gphRepopt.profileObstTrans()
  if( !repreObstructionValue.set() ) then
    !!gphRepopt.profileObstTrans(!repreObstructionValue)
    handle any
    endhandle
  endif
  VAR !coreRepreObst REPRESENTATION PROFILE OBSTRUCTION
  !coreObstructionOn = !coreRepreObst.upcase().eq('ON')
  if( !repreObstructionState.neq(!coreObstructionOn) ) then
    !!gphRepopt.profileObst(!repreObstructionState)
    handle any
    endhandle
    !!gphRepopt.update()
  endif

  -- Force the main graphics window to refresh to clear the laser clash highlight
  !!gphViews.views[1].refresh()
  handle any
  endhandle

endmethod
------------------------------------------------------------------------
--
-- Method:      ButtonInitControl
--
-- Description: Sets Remove button active in frame Obstruction.
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .buttonInitControl()

  !this.btnExclRem.active = FALSE
  !this.btnObstRem.active = FALSE

endmethod

-- Options set/get

------------------------------------------------------------------------
--
-- Method: RestoreDefaults
--
-- Description: Method for setting the clash user defaults.
--
-- Method Type: Procedure
-- Arguments:
--   [#]     [R/RW]   [Data Type]   [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .restoreDefaults()

  !this.restoreSavedOptions(|NORMAL|, |AVEVA_DESIGN_DFLTS|, true)
  !this.restoreSavedOptions(|REPORT|, |AVEVA_DESIGN_DFLTS|, true)

endmethod
------------------------------------------------------------------------
--
-- Method:      GetOptions
--
-- Description: Loads the option controls in the whole form.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .getOptions()
  -- Set display lists

  -- Set the Obstruction list
  !this.displayObst()

  -- Set the Exclusion list
  !this.displayExcl()

  -- Set the Limits list
  !this.limitsDisplay()

  -- Set the general clash options

  -- Set the Ignored within toggles
  !this.getIgnored()

  -- Midpoint option
  !this.tglCmp.val = !this.clasher.midpointGet()

  -- Touch gap value
  !this.txtGap.val = !this.clasher.touchingGapGet()

  -- Touch clearance value
  !this.txtClr.val = !this.clasher.clearanceGet()

  -- Touch overlap value
  !this.txtOvr.val = !this.clasher.touchingOverlapGet()

  -- Clash major representation colour
  !this.btnMci.background = !this.clasher.colourMajorGet()
  !this.parMcC.val        = !!colourName(!this.btnMci.background.real())

  -- Clash obstruction items representation colour
  !this.btnObi.background = !this.clasher.colourObstructGet()
  !this.parObC.val        = !!colourName(!this.btnObi.background.real())

  -- View Background colour
  !this.btnViewColour.background = !this.view.background
  !this.parViewColourName.val    = !!colourName(!this.btnViewColour.background.real())

  -- Get report options
  !this.clasher.reportSettingsGet()

  -- Set the form report controls

  -- Graphical option
  if (!this.clasher.reportGraphical) then
    !this.btnMci.background = !this.clasher.colourMajorGet()
    !this.btnObi.background = !this.clasher.colourObstructGet()
  endif

  -- Header option
  if(!this.clasher.reportHeader) then
    !this.tglHeadOn.val = TRUE
  else
    !this.tglHeadOn.val = FALSE
  endif

  -- Obstruction option
  if(!this.clasher.reportObstruct) then
    !this.tglObstrOn.val = TRUE
  else
    !this.tglObstrOn.val = FALSE
  endif

  -- Main body option
  if(!this.clasher.reportMain) then
    !this.tglMainOn.val = TRUE
  else
    !this.tglMainOn.val = FALSE
  endif

  -- Position option
  if(!this.clasher.reportPosition eq 'WORLD') then
    !this.tglPosWrld.val = TRUE
  elseif (!this.clasher.reportPosition eq 'SITE') then
    !this.tglPosSt.val = TRUE
  else
    !this.tglPosOff.val = TRUE
  endif

  -- Approved option
  --   if(!this.clasher.reportApproved) then
  --      !this.tglApprOn.val = TRUE
  --   else
  --      !this.tglApprOn.val = FALSE
  --   endif

  -- Reference option
  if(!this.clasher.reportReference) then
    !this.tglRefOn.val = TRUE
  else
    !this.tglRefOn.val = FALSE
  endif

  -- Numbering option
  if(!this.clasher.reportNumbering) then
    !this.tglNmbOn.val = TRUE
  else
    !this.tglNmbOn.val = FALSE
  endif

  -- Primary option
  if(!this.clasher.reportPrimary) then
    !this.tglPrmOn.val = TRUE
  else
    !this.tglPrmOn.val = FALSE
  endif

  -- Duplicate option
  if(!this.clasher.reportDuplicate eq 'FIRST') then
    !this.tglDupFst.val = TRUE
  elseif (!this.clasher.reportDuplicate eq 'SECOND') then
    !this.tglDupSnd.val = TRUE
  else
    !this.tglDupBth.val = TRUE
  endif

  -- Significant option
  !this.getSections()
  if(!this.clasher.reportSignificant) then
    !this.tglSigOn.val = TRUE
    !this.lstSignificant.active = TRUE
  else
    !this.tglSigOn.val = FALSE
    !this.lstSignificant.active = FALSE
  endif

  -- Levels option
  if(!this.clasher.reportLevels.findFirst('Clashes').set()) then
    !this.tglLvlCls.val = TRUE
  else
    !this.tglLvlCls.val = FALSE
  endif
  if(!this.clasher.reportLevels.findFirst('Touches').set()) then
    !this.tglLvlTch.val = TRUE
  else
    !this.tglLvlTch.val = FALSE
  endif
  if(!this.clasher.reportLevels.findFirst('Clearances').set()) then
    !this.tglLvlClr.val = TRUE
  else
    !this.tglLvlClr.val = FALSE
  endif

  -- Summary option
  if(!this.clasher.reportSummary) then
    !this.tglSmmrOn.val = TRUE
  else
    !this.tglSmmrOn.val = FALSE
  endif

  --Set touches include in clasher (we cannot read them from the system)
  !this.optTch.select('RTEXT','TRUE')
  !this.clasher.start()
  !this.clasher.touchesInclude()

  --Get the type of check for the pipes
  if (!this.clasher.clashesIgnoredGet().findFirst('BRAN').set()) then
    !this.optCwb.select('RTEXT','NOCHECK')
  else
    if (!this.clasher.branchesCheckTypeGet() eq 'ACHECK') then
      !this.optCwb.select('RTEXT','ACHECK')
    else
      !this.optCwb.select('RTEXT','BCHECK')
    endif
  endif

  --Set connections include in clasher (we cannot read them from the system)
  !this.optCon.select('RTEXT','INCLUDE CONNECTIONS')
  !this.clasher.connectionsInclude()
  !this.clasher.end()

  -- Non-DESCLASH options
  !this.groupOptionCallback()
  !this.netAfterSelectChangeCallback(!this.dbCtrl.getSelectedRows())

endmethod
------------------------------------------------------------------------
--
-- Method:      SetOptions
--
-- Description: Updates the system clasher options based on GUI selections.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setOptions()

  -- Enter DESCLASH MODE
  !this.clasher.start()

  -- Set the general clash options

  -- Midpoint option
  !this.clasher.midpointSet(!this.tglCmp.val)

  -- Remember the current setting in case there is bad input and we have to return to current setting
  !txtGap = !this.clasher.touchingGapGet()
  !txtClr = !this.clasher.clearanceGet()
  !txtOvr = !this.clasher.touchingOverlapGet()

  -- Touch gap value
  if(!this.clasher.touchingGapSet(!this.txtGap.val).not()) then
    !!alert.error(!!error.text)
    !this.txtGap.val = !txtGap
  endif

  -- Touch clearance value
  if(!this.clasher.clearanceSet(!this.txtClr.val).not()) then
    !!alert.error(!!error.text)
    !this.txtClr.val = !txtClr
  endif

  -- Touch overlap value
  if(!this.clasher.touchingOverlapSet(!this.txtOvr.val).not()) then
    !!alert.error(!!error.text)
    !this.txtOvr.val = !txtOvr
  endif

  -- Update the laser options
  $!this.optLaserDisplay
  $!this.optLaserTest

  -- Clash major representation colour
  !this.clasher.colourMajorSet(!!colourName(!this.btnMci.background))
  !this.parMcC.val   = !!colourName(!this.btnMci.background.real())

  -- Clash obstruction items representation colour
  !this.clasher.colourObstructSet(!!colourName(!this.btnObi.background))
  !this.parObC.val   = !!colourName(!this.btnObi.background.real())

  --Set check options (Touches ignored included)
  if (!this.optTch.selection('RTEXT') eq 'TRUE') then
    !this.clasher.touchesInclude()
  else
    !this.clasher.touchesIgnore()
  endif

  --Set pipe check mode
  if (!this.optCwb.selection('RTEXT') eq 'ACHECK') then
    !this.clasher.branchesCheckTypeSet('ACHECK')
    !this.clasher.clashesWithinInclude('BRA')
    !this.tglBran.val = FALSE
  elseif (!this.optCwb.selection('RTEXT') eq 'BCHECK') then
    !this.clasher.branchesCheckTypeSet('BCHECK')
    !this.clasher.clashesWithinInclude('BRA')
    !this.tglBran.val = FALSE
  else
    !this.clasher.clashesWithinIgnore('BRA')
    !this.tglBran.val = TRUE
  endif

  --Set connections check mode
  if (!this.optCon.selection('RTEXT') eq 'INCLUDE CONNECTIONS') then
    !this.clasher.connectionsInclude()
  elseif (!this.optCon.selection('RTEXT') eq 'IGNORE CONNECTIONS') then
    !this.clasher.connectionsIgnore()
  else
    !this.clasher.connectionsIgnore('WITHSPEC')
  endif

  -- Exit DESCLASH MODE
  !this.clasher.end()

endmethod
------------------------------------------------------------------------
--
-- Method:      SaveOptions
--
-- Description: Saves the system clasher options based on GUI selections.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .saveOptions()

  -- save the units to file
  !saveCommands = ARRAY()
  !project      = CURRENT PROJECT
  -- Capture current units
  var !units SPLIT UNITS
  if (!units[3] eq 'MM') then
    !file = object FILE('%AVEVA_DESIGN_USER%/' + !project.code() + '-save-clasher-Met.pmldat')
  else
    !file = object FILE('%AVEVA_DESIGN_USER%/' + !project.code() + '-save-clasher-Imp.pmldat')
  endif

  -- Midpoint option
  !midpointGot = !this.tglCmp.val.string()

  -- Touch gap value
  !touchingGapGot = !this.txtGap.val.string(!!distanceFmt)

  -- Touch clearance value
  !clearanceGot = !this.txtClr.val.string(!!distanceFmt)

  -- Touch overlap value
  !touchingOverlapGot = !this.txtOvr.val.string(!!distanceFmt)

  -- Clash major representation colour
  !majorColourGot = !this.btnMci.background.real().string()

  -- Clash obstruction items representation colour
  !obstructColourGot = !this.btnObi.background.real().string()
  !viewColourGot     = !this.btnViewColour.background.real().string()

  --Set check options (Touches ignored included)
  if (!this.optTch.selection('RTEXT') eq 'TRUE') then
    !touchesIgnoreInclude = '!this.clasher.touchesInclude()'
    !touchesGadget = '!this.optTch.select(|RTEXT|,|TRUE|)'
  else
    !touchesIgnoreInclude = '!this.clasher.touchesIgnore()'
    !touchesGadget = '!this.optTch.select(|RTEXT|,|FALSE|)'
  endif

  --Set pipe check mode
  if (!this.optCwb.selection('RTEXT') eq 'ACHECK') then
    !checkAorBgot = '!this.clasher.branchesCheckTypeSet(|ACHECK|)'
    !checkWithinBranchGot = '!this.clasher.clashesWithinInclude(|BRA|)'
    !toggleBranchGot = 'FALSE'
    !checkWithinBranchGadget = '!this.optCwb.select(|RTEXT|,|ACHECK|)'
  elseif (!this.optCwb.selection('RTEXT') eq 'BCHECK') then
    !checkAorBgot = '!this.clasher.branchesCheckTypeSet(|BCHECK|)'
    !checkWithinBranchGot = '!this.clasher.clashesWithinInclude(|BRA|)'
    !toggleBranchGot = 'FALSE'
    !checkWithinBranchGadget = '!this.optCwb.select(|RTEXT|,|BCHECK|)'
  else
    !checkAorBgot = ' '
    !checkWithinBranchGot = '!this.clasher.clashesWithinIgnore(|BRA|)'
    !toggleBranchGot = 'TRUE'
    !checkWithinBranchGadget = '!this.optCwb.select(|RTEXT|,|NOCHECK|)'
  endif

  --Set connections check mode
  if (!this.optCon.selection('RTEXT') eq 'INCLUDE CONNECTIONS') then
    !checkConnectionsGot = '!this.clasher.connectionsInclude()'
    !connectionsGadget   = '!this.optCon.select(|RTEXT|,|INCLUDE CONNECTIONS|)'
  elseif (!this.optCon.selection('RTEXT') eq 'IGNORE CONNECTIONS') then
    !checkConnectionsGot = '!this.clasher.connectionsIgnore()'
    !connectionsGadget   = '!this.optCon.select(|RTEXT|,|IGNORE CONNECTIONS|)'
  else
    !checkConnectionsGot = '!this.clasher.connectionsIgnore(|WITHSPEC|)'
    !connectionsGadget   = '!this.optCon.select(|RTEXT|,|IGNORE CONNECTIONS WITH SPECIFICATION|)'
  endif

  -- Presentation defaults
  !tglPresentGroupGot         = !this.tglPresentGroup.val.string()
  !tglPresentClashItemGot     = !this.tglPresentClashItem.val.string()
  !tglPresentObstructionGot   = !this.tglPresentObstruction.val.string()
  !tglPresentClashPositionGot = !this.tglPresentClashPosition.val.string()

  --Reset ignore toggles
  !tglGensecGot = !this.tglGensec.val.string()
  !tglTmplGot = !this.tglTmpl.val.string()
  !tglCwBranGot = !this.tglCwBran.val.string()
  !tglPltfrmGot = !this.tglPltfrm.val.string()
  !tglSctnGot = !this.tglSctn.val.string()
  !tglBranGot = !this.tglBran.val.string()
  !tglPcojGot = !this.tglPcoj.val.string()
  !tglSiteGot = !this.tglSite.val.string()
  !tglZoneGot = !this.tglZone.val.string()
  !tglPipeGot = !this.tglPipe.val.string()
  !tglStrGot = !this.tglStr.val.string()
  !tglRestrGot = !this.tglRestr.val.string()
  !tglEquGot = !this.tglEqu.val.string()
  !tglHangGot = !this.tglHang.val.string()
  !tglSubsGot = !this.tglSubs.val.string()
  !tglFrmwGot = !this.tglFrmw.val.string()
  !tglSbfrmGot = !this.tglSbfrm.val.string()
  !tglPtrGot = !this.tglPtr.val.string()
  !tglStrfltGot = !this.tglStrflt.val.string()
  !tglRladdrGot = !this.tglRladdr.val.string()
  !tglSladdrGot = !this.tglSladdr.val.string()
  !tglHandraGot = !this.tglHandra.val.string()
  !tglCSURPXGot = !this.tglCSURPX.val.string()
  !tglHVACGot   = !this.tglHVAC.val.string()
  !tglHPanelGot = !this.tglHPanel.val.string()
  !tglUPanelGot = !this.tglUPanel.val.string()
  !tglConveyGot = !this.tglConvey.val.string()
  !clashTest    = !this.optLaserTest
  !clashDisplay = !this.optLaserDisplay

  -- build up commands
  !saveCommands.append('-- AVEVA - Clasher serialisation file                                     ')
  !saveCommands.append('-- ----------------------------------                                     ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Initialise variables                                                   ')
  !saveCommands.append('!this = !!avaclasherui                                                    ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Enter DESCLASH MODE                                                    ')
  !saveCommands.append('!this.clasher.start()                                                     ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Set the general clash options                                          ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Midpoint option                                                        ')
  !saveCommands.append('!this.clasher.midpointSet(' & !midpointGot & ')                           ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Touch gap value                                                        ')
  !saveCommands.append('!this.clasher.touchingGapSet(' & !touchingGapGot & ')                     ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Touch clearance value                                                  ')
  !saveCommands.append('!this.clasher.clearanceSet(' & !clearanceGot & ')                         ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Touch overlap value                                                    ')
  !saveCommands.append('!this.clasher.touchingOverlapSet(' & !touchingOverlapGot & ')             ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Clash major representation colour                                      ')
  !saveCommands.append('!this.clasher.colourMajorSet(!!colourName(' & !majorColourGot & '))       ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Clash obstruction items representation colour                          ')
  !saveCommands.append('!this.clasher.colourObstructSet(!!colourName(' & !obstructColourGot & ')) ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Point Cloud clash options                                              ')
  !saveCommands.append('!this.clasher.command(|$!clashTest|)                                      ')
  !saveCommands.append('!this.clasher.command(|$!clashDisplay|)                                   ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Exit DESCLASH MODE                                                     ')
  !saveCommands.append('!this.clasher.end()                                                       ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Point Cloud clash options                                              ')
  !saveCommands.append('!this.optLaserTest.select(|RTEXT|, |$!clashTest|)                         ')
  !saveCommands.append('!this.optLaserDisplay.select(|RTEXT|, |$!clashDisplay|)                   ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Clash view colour                                                      ')
  !saveCommands.append('!viewColour = object COLOUR(' & !viewColourGot & ')                       ')
  !saveCommands.append('!colourCode = !viewColour.code                                            ')
  !saveCommands.append('!colourName = !viewColour.name                                            ')
  !saveCommands.append('!this.view.background = !colourCode                                       ')
  !saveCommands.append('!this.btnViewColour.background = !colourCode                              ')
  !saveCommands.append('!this.parViewColourName.val    = !colourName                              ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Presentation defaults                                                  ')
  !saveCommands.append('!this.tglPresentGroup.val = ' & !tglPresentGroupGot                        )
  !saveCommands.append('!this.tglPresentClashItem.val = ' & !tglPresentClashItemGot                )
  !saveCommands.append('!this.tglPresentObstruction.val = ' & !tglPresentObstructionGot            )
  !saveCommands.append('!this.tglPresentClashPosition.val = ' & !tglPresentClashPositionGot        )
  !saveCommands.append('                                                                          ')
  !saveCommands.append('--Reset ignore toggles                                                    ')
  !saveCommands.append('!this.tglGensec.val = ' & !tglGensecGot                                    )
  !saveCommands.append('!this.tglTmpl.val   = ' & !tglTmplGot                                      )
  !saveCommands.append('!this.tglCwBran.val = ' & !tglCwBranGot                                    )
  !saveCommands.append('!this.tglPltfrm.val = ' & !tglPltfrmGot                                    )
  !saveCommands.append('!this.tglSctn.val   = ' & !tglSctnGot                                      )
  !saveCommands.append('!this.tglBran.val   = ' & !tglBranGot                                      )
  !saveCommands.append('!this.tglPcoj.val   = ' & !tglPcojGot                                      )
  !saveCommands.append('!this.tglSite.val   = ' & !tglSiteGot                                      )
  !saveCommands.append('!this.tglZone.val   = ' & !tglZoneGot                                      )
  !saveCommands.append('!this.tglPipe.val   = ' & !tglPipeGot                                      )
  !saveCommands.append('!this.tglStr.val    = ' & !tglStrGot                                       )
  !saveCommands.append('!this.tglRestr.val  = ' & !tglRestrGot                                     )
  !saveCommands.append('!this.tglEqu.val    = ' & !tglEquGot                                       )
  !saveCommands.append('!this.tglHang.val   = ' & !tglHangGot                                      )
  !saveCommands.append('!this.tglSubs.val   = ' & !tglSubsGot                                      )
  !saveCommands.append('!this.tglFrmw.val   = ' & !tglFrmwGot                                      )
  !saveCommands.append('!this.tglSbfrm.val  = ' & !tglSbfrmGot                                     )
  !saveCommands.append('!this.tglPtr.val    = ' & !tglPtrGot                                       )
  !saveCommands.append('!this.tglHVAC.val   = ' &!tglHVACGot                                       )
  !saveCommands.append('!this.tglCSURPX.val = ' & !tglCSURPXGot                                    )
  !saveCommands.append('!this.tglHPanel.val = ' & !tglHPanelGot                                    )
  !saveCommands.append('!this.tglUPanel.val = ' & !tglUPanelGot                                    )
  !saveCommands.append('!this.tglStrflt.val = ' & !tglStrfltGot                                    )
  !saveCommands.append('!this.tglRladdr.val = ' & !tglRladdrGot                                    )
  !saveCommands.append('!this.tglSladdr.val = ' & !tglSladdrGot                                    )
  !saveCommands.append('!this.tglHandra.val = ' & !tglHandraGot                                    )
  !saveCommands.append('!this.tglConvey.val = ' & !tglConveyGot                                    )
  !saveCommands.append('!this.setIgnored()                                                        ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Update Gadgets with the current Clasher settings                       ')
  !saveCommands.append('!this.getOptions()                                                        ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Enter DESCLASH MODE                                                    ')
  !saveCommands.append('!this.clasher.start()                                                     ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('--Set check options (Touches ignored included)                            ')
  !saveCommands.append(!touchesIgnoreInclude                                                       )
  !saveCommands.append(!touchesGadget                                                              )
  !saveCommands.append('                                                                          ')
  !saveCommands.append('--Set pipe check mode                                                     ')
  !saveCommands.append(!checkAorBgot                                                               )
  !saveCommands.append(!checkWithinBranchGot                                                       )
  !saveCommands.append('!this.tglBran.val = '& !toggleBranchGot                                    )
  !saveCommands.append(!checkWithinBranchGadget                                                  )
  !saveCommands.append('                                                                          ')
  !saveCommands.append('--Set connections check mode                                              ')
  !saveCommands.append(!checkConnectionsGot                                                        )
  !saveCommands.append(!connectionsGadget                                                          )
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Exit DESCLASH MODE                                                     ')
  !saveCommands.append('!this.clasher.end()                                                       ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- End of... AVEVA - Clasher serialisation file                           ')

  -- write commands to file
  !file.writefile('OVERWRITE',!saveCommands)
  !file.close()

endmethod
------------------------------------------------------------------------
--
-- Method:      SaveReportOptions
--
-- Description: Saves the system clasher report options based on GUI selections.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .saveReportOptions()

  -- save the units to file
  !saveCommands = ARRAY()
  !project      = CURRENT PROJECT
  !file = object FILE('%AVEVA_DESIGN_USER%/' + !project.code() + '-save-clasherRep.pmldat')

  -- Reporting Options

  -- Report option
  !tglRepSaveGot = !this.tglRepSave.val.string()

  -- Header option
  !tglHeadOnGot = !this.tglHeadOn.val.string()

  -- Obstruction option
  !tglObstrOnGot = !this.tglObstrOn.val.string()

  -- Main body option
  !tglMainOnGot = !this.tglMainOn.val.string()

  -- Summary option
  !tglSmmrOnGot = !this.tglSmmrOn.val.string()

  -- Reference option
  !tglRefOnGot = !this.tglRefOn.val.string()

  -- Numbering option
  !tglNmbOnGot = !this.tglNmbOn.val.string()

  -- Primary option
  !tglPrmOnGot = !this.tglPrmOn.val.string()

  -- Position option
  if(!this.tglPosWrld.val) then
    !positionTypeGot = 'WORLD'
  elseif (!this.tglPosSt.val) then
    !positionTypeGot = 'SITE'
  else
    !positionTypeGot = 'OFF'
  endif

  -- Duplicate option
  if(!this.tglDupFst.val) then
    !duplicateTypeGot = 'FIRST'
  elseif (!this.tglDupSnd.val) then
    !duplicateTypeGot = 'SECOND'
  else
    !duplicateTypeGot = 'BOTH'
  endif

  -- Levels option
  !levelsGot = ARRAY()
  if(!this.tglLvlCls.val) then
    !levelsGot.append('Clashes')
  endif
  if(!this.tglLvlTch.val) then
    !levelsGot.append('Touches')
  endif
  if(!this.tglLvlClr.val) then
    !levelsGot.append('Clearances')
  endif

  -- Significant option
  !tglSigOnGot = !this.tglSigOn.val.string()
  !lstSignificantGot = !this.lstSignificant.dtext

  -- build up commands
  !saveCommands.append('-- AVEVA - Clasher report serialisation file                              ')
  !saveCommands.append('-- -----------------------------------------                              ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Initialise variables                                                   ')
  !saveCommands.append('!this = !!avaclasherui                                                    ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Set the form report controls                                           ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Enter DESCLASH MODE                                                    ')
  !saveCommands.append('!this.clasher.start()                                                     ')
  !saveCommands.append('-- Header option                                                          ')
  !saveCommands.append('!this.clasher.reportSettingsSet(|HEADER|,' & !tglHeadOnGot & ')           ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Obstruction option                                                     ')
  !saveCommands.append('!this.clasher.reportSettingsSet(|OBSTRUCT|,' & !tglObstrOnGot & ')        ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Main body option                                                       ')
  !saveCommands.append('!this.clasher.reportSettingsSet(|MAIN|,' & !tglMainOnGot & ')             ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Summary option                                                         ')
  !saveCommands.append('!this.clasher.reportSettingsSet(|SUMMARY|,' & !tglSmmrOnGot & ')          ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Reference option                                                       ')
  !saveCommands.append('!this.clasher.reportSettingsSet(|REF|,' & !tglRefOnGot & ')               ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Numbering option                                                       ')
  !saveCommands.append('!this.clasher.reportSettingsSet(|NUMBER|,' & !tglNmbOnGot & ')            ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Primary option                                                         ')
  !saveCommands.append('!this.clasher.reportSettingsSet(|PRIMARY|,' & !tglPrmOnGot & ')           ')
  !saveCommands.append('                                                                          ')

  !saveCommands.append('-- Position option                                                        ')
  !saveCommands.append('!this.clasher.reportPositionSet(|' & !positionTypeGot & '|)                 ')

  !saveCommands.append('-- Duplicate option                                                       ')
  !saveCommands.append('!this.clasher.reportUnderSet(|' & !duplicateTypeGot & '|)                   ')

  !saveCommands.append('-- Levels option                                                          ')
  !saveCommands.append('!levelArray = ARRAY()                                                     ')
  do !i indices !levelsGot
    !saveCommands.append('!levelArray.append(|' & !levelsGot[!i] & '|)                              ')
  enddo
  if (!levelsGot.size() gt 0) then
    !saveCommands.append('!this.clasher.reportLevelSet(!levelArray)                                 ')
  endif

  !saveCommands.append('-- Significant option                                                     ')
  !saveCommands.append('!this.tglSigOn.val = ' & !tglSigOnGot                                      )
  !saveCommands.append('--Activate significant frame?                                             ')
  !saveCommands.append('!this.lstSignificant.active = ' & !tglSigOnGot                             )
  !saveCommands.append('!this.clasher.reportSettingsSet(|SIGNIF|,' & !tglSigOnGot & ')            ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('--Set report significant list                                             ')
  !saveCommands.append('!elementsArray = ARRAY()                                                  ')
  do !i indices !lstSignificantGot
    !saveCommands.append('!elementsArray.append(|' & !lstSignificantGot[!i] & '|)                   ')
  enddo
  !saveCommands.append('!this.lstSignificant.dtext = !elementsArray                               ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Exit DESCLASH MODE                                                     ')
  !saveCommands.append('!this.clasher.end()                                                       ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Save Report option                                                     ')
  !saveCommands.append('!this.tglRepSave.val = ' & !tglRepSaveGot                                  )
  !saveCommands.append('!this.activeInactiveReportOptions()                                       ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Update Gadgets with the current Clasher settings                       ')
  !saveCommands.append('!this.getOptions()                                                        ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- End of... AVEVA - Clasher report serialisation file                    ')

  -- write commands to file
  !file.writefile('OVERWRITE',!saveCommands)
  !file.close()

endmethod
------------------------------------------------------------------------
--
-- Method:      exclListSave
--
-- Description: Saves the system clasher exclusion list
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListSave()

  -- save the exclusion list to file
  !saveCommands = ARRAY()
  !project      = CURRENT PROJECT
  !session      = CURRENT SESSION
  !file = object FILE('%AVEVA_DESIGN_USER%/' + !project.code() + '-' + !session.mdb().string().after( '/' ) + '-save-clasher-exclusion.pmldat')

  !saveCommands.append(' -- Start DESCLASH, Add the element to the exclusion list                 ')
  !saveCommands.append('-- ------------------------------------------------------                 ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Initialise variables                                                   ')
  !saveCommands.append('!this = !!avaclasherui                                                    ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Enter DESCLASH MODE                                                    ')
  !saveCommands.append('!this.clasher.start()                                                     ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Clear existing exclusion list                                          ')
  !saveCommands.append('!this.clasher.exclusionClear()                                            ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Now exclude the following elements                                     ')
  !saveCommands.append('                                                                          ')
  --Gets the exclusion list
  !exclusionList = !this.clasher.exclusionListGet()
  do !index indices !exclusionList
    !exclusionElement = !exclusionList[!index]
    !name = !exclusionElement.attribute( 'name' )
    !saveCommands.append('!element = OBJECT DBREF ( |$!name| )                                   ')
    !saveCommands.append(' HANDLE NONE                                                           ')
    !saveCommands.append('   !this.clasher.exclusionAdd(!element)                                ')
    !saveCommands.append(' ELSEHANDLE ANY                                                        ')
    !saveCommands.append(' ENDHANDLE                                                             ')
    !saveCommands.append('                                                                       ')
  enddo
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Exit DESCLASH MODE                                                     ')
  !saveCommands.append('!this.clasher.end()                                                       ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- Display exclusion list                                                 ')
  !saveCommands.append('!this.displayExcl()                                                       ')
  !saveCommands.append('                                                                          ')
  !saveCommands.append('-- End of... AVEVA - Clasher exclusion list file                          ')

  -- write commands to file
  !file.writefile('OVERWRITE',!saveCommands)
  !file.close()

endmethod
------------------------------------------------------------------------
--
-- Method:      exclListRestore
--
-- Description: Restore the system clasher exclusion list
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListRestore()

  -- save the units to file
  !project      = CURRENT PROJECT
  !session      = CURRENT SESSION
  !fileString = '%AVEVA_DESIGN_USER%/' + !project.code() + '-' + !session.mdb().string().after( '/' ) + '-save-clasher-exclusion.pmldat'
  !file = object FILE(!fileString)

  if (!file.exists()) then
    !!runMacro(!fileString, '')
    handle ANY
      !!alert.error('There is a problem with Saved Clasher Exclusion List file ' & !fileString)
    endhandle
  else
    !!alert.error('Saved Clasher Exclusion List file not found ' & !fileString)
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      restoreSavedOptions
--
-- Description: Restores the saved File, Saved based on GUI selections.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R     STRING      Key word REPORT or NORMAL
--    2    R     STRING      AVEVA_DESIGN_DFLTS or AVEVA_DESIGN_USER
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .restoreSavedOptions(!option is STRING, !location is STRING, !warn is BOOLEAN)

  -- Define name for file name
  if (!option.upcase() eq 'REPORT') then
    !keyWord = 'clasherRep'
  else
    !keyWord = 'clasher'
  endif

  -- save the units to file
  !project      = CURRENT PROJECT
  -- Capture current units
  var !units SPLIT UNITS
  if (!location eq 'AVEVA_DESIGN_USER') then
    if (!keyWord eq 'clasherRep') then
      !fileString = '%' & !location & '%/' & !project.code() & '-save-' & !keyWord & '.pmldat'
      !file = object FILE(!fileString)
    elseif (!units[3] eq 'MM' and !keyWord eq 'clasher') then
      !fileString = '%' & !location & '%/' & !project.code() & '-save-' & !keyWord & '-Met.pmldat'
      !file = object FILE(!fileString)
    else
      !fileString = '%' & !location & '%/' & !project.code() & '-save-' & !keyWord & '-Imp.pmldat'
      !file = object FILE(!fileString)
    endif
  elseif (!location eq 'AVEVA_DESIGN_DFLTS') then
    if (!keyWord eq 'clasherRep') then
      !fileString = '%' & !location & '%/system-clasherReport.pmldat'
      !file = object FILE(!fileString)
    elseif (!units[3] eq 'MM' and !keyWord eq 'clasher') then
      !fileString = '%' & !location & '%/system-' & !keyWord & '-Met.pmldat'
      !file = object FILE(!fileString)
    else
      !fileString = '%' & !location & '%/system-' & !keyWord & '-Imp.pmldat'
      !file = object FILE(!fileString)
    endif
  endif

  if (!file.exists()) then
    !!runMacro(!fileString, '')
    handle ANY
      if (!location eq 'AVEVA_DESIGN_USER') then
        !!alert.error('There is a problem with User Saved Clasher Settings file ' & !fileString)
      else
        !!alert.error('There is a problem with System Clasher Defaults file ' & !fileString)
      endif
    endhandle
  else
    if (!warn) then
      if (!location eq 'AVEVA_DESIGN_USER') then
        !!alert.error('User Saved Clasher Settings file not found ' & !fileString)
      else
        !!alert.error('System Clasher Defaults file not found ' & !fileString)
      endif
    endif
  endif

endmethod

------------------------------------------------------------------------
--
-- Method:      SetReportOptions
--
-- Description: Updates the changed report options.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setReportOptions()

  -- Enter DESCLASH MODE
  !this.clasher.start()

  -- Set the form report controls

  --Colour control
  --   !this.btnMci.background = !this.clasher.colourMajorGet()
  --   !this.btnObi.background = !this.clasher.colourObstructGet()

  -- Turn ON graphical feedback
  !this.clasher.reportSettingsSet('GRAPHICS',TRUE)

  -- Header option
  !this.clasher.reportSettingsSet('HEADER',!this.tglHeadOn.val)

  -- Obstruction option
  !this.clasher.reportSettingsSet('OBSTRUCT',!this.tglObstrOn.val)

  -- Main body option
  !this.clasher.reportSettingsSet('MAIN',!this.tglMainOn.val)

  -- Summary option
  !this.clasher.reportSettingsSet('SUMMARY',!this.tglSmmrOn.val)

  -- Approved option
  --   !this.clasher.reportSettingsSet('APPROVED',!this.tglApprOn.val)

  -- Reference option
  !this.clasher.reportSettingsSet('REF',!this.tglRefOn.val)

  -- Numbering option
  !this.clasher.reportSettingsSet('NUMBER',!this.tglNmbOn.val)

  -- Primary option, in reality these ALL switches should only be applied if
  -- enabled but this one really hurts if incorrectly applied.
  !this.clasher.reportSettingsSet('PRIMARY', (!this.tglRepSave.val AND !this.tglPrmOn.val))

  -- Position option
  if(!this.tglPosWrld.val) then
    !type = 'WORLD'
  elseif (!this.tglPosSt.val) then
    !type = 'SITE'
  else
    !type = 'OFF'
  endif

  !this.clasher.reportPositionSet(!type)

  -- Duplicate option
  if(!this.tglDupFst.val) then
    !type = 'FIRST'
  elseif (!this.tglDupSnd.val) then
    !type = 'SECOND'
  else
    !type = 'BOTH'
  endif

  !this.clasher.reportUnderSet(!type)

  -- Levels option
  !levels = ARRAY()

  -- Check if at least one level option is selected
  !anySelected = FALSE

  if(!this.tglLvlCls.val) then
    !levels.append('Clashes')
    !anySelected = TRUE
  endif
  if(!this.tglLvlTch.val) then
    !levels.append('Touches')
    !anySelected = TRUE
  endif
  if(!this.tglLvlClr.val) then
    !levels.append('Clearances')
    !anySelected = TRUE
  endif

  -- Select default 'Clashes' option if there is no selection
  if(!anySelected.not()) then
    !this.tglLvlCls.val = TRUE
    !levels.append('Clashes')
    !!alert.error('At least one level option must be selected! DEFAULT:Clashes')
  endif

  if(!levels.size() gt 0) then
    !this.clasher.reportLevelSet(!levels)
  endif

  -- Significant option ( Always put this setting after all settings because for example level options turn off the significant option setting)
  !this.clasher.reportSettingsSet('SIGNIF',!this.tglSigOn.val)

  --Set report significant list
  !this.getSections()
  if (!this.tglSigOn.val) then
    --Activate significant frame
    !this.lstSignificant.active = TRUE
  else
    --Deactivate significant frame
    !this.lstSignificant.active = FALSE
  endif

  -- Exit DESCLASH MODE
  !this.clasher.end()

endmethod

------------------------------------------------------------------------
--
-- Method:      SetColorOptions
--
-- Description: Set color for clash type.
--
-- Method Type: Procedure
-- Arguments:
--   [#]    [R/RW] [Data Type] [Description]
--   !type   R      REAL       1 - 'MAJOR', 2 - 'MINOR' color type
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setColorOptions(!type is REAL)

  if (!type eq 1) then
    !this.btnMci.background = !!colourSelectGet()
  elseif (!type eq 2) then
    !this.btnObi.background = !!colourSelectGet()
  else
    !viewColour = object COLOUR(!!colourSelectGet())
    !colourCode = !viewColour.code
    !colourName = !viewColour.name
    !this.view.background = !colourCode
    !this.btnViewColour.background = !colourCode
    !this.parViewColourName.val    = !colourName
  endif

  !this.setOptions()

endmethod
------------------------------------------------------------------------
--
-- Method:      SetIgnored
--
-- Description: Set the list of clashes ignored within.
--
-- Method Type: Procedure
-- Arguments:
--   [#]    [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setIgnored()

  -- Enter DESCLASH mode
  !this.clasher.start()

  --Clear ignore within list
  do !type values !this.clasher.clashesIgnoredGet()
    !this.clasher.clashesWithinInclude(!type)
  enddo

  -- Check all ignore within toggles
  if (!this.tglGensec.val) then
    !this.clasher.clashesWithinIgnore(!this.tglGensec.tag)
  endif

  if (!this.tglBran.val) then
    !this.clasher.clashesWithinIgnore(!this.tglBran.tag)
    !this.optCwb.select('RTEXT','NOCHECK')
  else
    if (!this.clasher.branchesCheckTypeGet() eq 'ACHECK') then
      !this.optCwb.select('RTEXT','ACHECK')
    else
      !this.optCwb.select('RTEXT','BCHECK')
    endif
  endif

  if (!this.tglTmpl.val) then
    !this.clasher.clashesWithinIgnore(!this.tglTmpl.tag)
  endif

  if (!this.tglCwBran.val) then
    !this.clasher.clashesWithinIgnore(!this.tglCwBran.tag)
  endif

  if (!this.tglPltfrm.val) then
    !this.clasher.clashesWithinIgnore(!this.tglPltfrm.tag)
  endif

  if (!this.tglSctn.val) then
    !this.clasher.clashesWithinIgnore(!this.tglSctn.tag)
  endif

  if (!this.tglPcoj.val) then
    !this.clasher.clashesWithinIgnore(!this.tglPcoj.tag)
  endif

  if (!this.tglSite.val) then
    !this.clasher.clashesWithinIgnore(!this.tglSite.tag)
  endif

  if (!this.tglZone.val) then
    !this.clasher.clashesWithinIgnore(!this.tglZone.tag)
  endif

  if (!this.tglPipe.val) then
    !this.clasher.clashesWithinIgnore(!this.tglPipe.tag)
  endif

  if (!this.tglStr.val) then
    !this.clasher.clashesWithinIgnore(!this.tglStr.tag)
  endif

  if (!this.tglRestr.val) then
    !this.clasher.clashesWithinIgnore(!this.tglRestr.tag)
  endif

  if (!this.tglEqu.val) then
    !this.clasher.clashesWithinIgnore(!this.tglEqu.tag)
  endif

  if (!this.tglHang.val) then
    !this.clasher.clashesWithinIgnore(!this.tglHang.tag)
  endif

  if (!this.tglSubs.val) then
    !this.clasher.clashesWithinIgnore(!this.tglSubs.tag)
  endif

  if (!this.tglFrmw.val) then
    !this.clasher.clashesWithinIgnore(!this.tglFrmw.tag)
  endif

  if (!this.tglSbfrm.val) then
    !this.clasher.clashesWithinIgnore(!this.tglSbfrm.tag)
  endif

  if (!this.tglPtr.val) then
    !this.clasher.clashesWithinIgnore(!this.tglPtr.tag)
  endif

  if (!this.tglCSURPX.val) then
    !this.clasher.clashesWithinIgnore('CSURPX')
    !this.clasher.clashesWithinIgnore('CPANEL')
  endif

  if (!this.tglHVAC.val) then
    !this.clasher.clashesWithinIgnore(!this.tglHVAC.tag)
  endif

  if (!this.tglHPanel.val) then
    !this.tglHPanel.val = !this.clasher.clashesWithinIgnore('HPANEL')
    if (!this.tglHPanel.val.not()) then
      !!alert.message('It is not sensible to set all options to ignored. The final one was dropped')
    endif
  endif

  if (!this.tglUPanel.val) then
    !this.clasher.clashesWithinIgnore(!this.tglUPanel.tag)
  endif

  if (!this.tglStrflt.val) then
    !this.clasher.clashesWithinIgnore(!this.tglStrflt.tag)
  endif

  if (!this.tglRladdr.val) then
    !this.clasher.clashesWithinIgnore(!this.tglRladdr.tag)
  endif

  if (!this.tglSladdr.val) then
    !this.clasher.clashesWithinIgnore(!this.tglSladdr.tag)
  endif

  if (!this.tglHandra.val) then
    !this.clasher.clashesWithinIgnore(!this.tglHandra.tag)
  endif

  if (!this.tglConvey.val) then
    !this.clasher.clashesWithinIgnore(!this.tglConvey.tag)
  endif

  -- exit DESCLASH mode
  !this.clasher.end()

endmethod
------------------------------------------------------------------------
--
-- Method:      GetIgnored
--
-- Description: Get the list of clashes ignored within and set form toggles.
--
-- Method Type: Procedure
-- Arguments:
--   [#]    [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .getIgnored()

  --Clear ignore toggles
  !this.tglGensec.val = FALSE
  !this.tglTmpl.val   = FALSE
  !this.tglCwBran.val = FALSE
  !this.tglPltfrm.val = FALSE
  !this.tglSctn.val   = FALSE
  !this.tglBran.val   = FALSE
  !this.tglPcoj.val   = FALSE
  !this.tglSite.val   = FALSE
  !this.tglZone.val   = FALSE
  !this.tglPipe.val   = FALSE
  !this.tglStr.val    = FALSE
  !this.tglRestr.val  = FALSE
  !this.tglEqu.val    = FALSE
  !this.tglHang.val   = FALSE
  !this.tglSubs.val   = FALSE
  !this.tglFrmw.val   = FALSE
  !this.tglSbfrm.val  = FALSE
  !this.tglPtr.val    = FALSE
  !this.tglCSURPX.val = FALSE
  !this.tglHVAC.val   = FALSE
  !this.tglHPanel.val = FALSE
  !this.tglUPanel.val = FALSE
  !this.tglStrflt.val = FALSE
  !this.tglRladdr.val = FALSE
  !this.tglSladdr.val = FALSE
  !this.tglHandra.val = FALSE
  !this.tglConvey.val = FALSE

  --Clear ignore within list
  do !type values !this.clasher.clashesIgnoredGet()

    -- Set all ignore within toggles
    if (!this.tglGensec.tag eq !type) then
      !this.tglGensec.val = TRUE
    endif

    if (!this.tglTmpl.tag eq !type) then
      !this.tglTmpl.val = TRUE
    endif

    if (!this.tglCwBran.tag eq !type) then
      !this.tglCwBran.val = TRUE
    endif

    if (!this.tglPltfrm.tag eq !type) then
      !this.tglPltfrm.val = TRUE
    endif

    if (!this.tglBran.tag eq !type) then
      !this.tglBran.val = TRUE
      !this.optCwb.select('RTEXT','NOCHECK')
    endif

    if (!this.tglSctn.tag eq !type) then
      !this.tglSctn.val = TRUE
    endif

    if (!this.tglPcoj.tag eq !type) then
      !this.tglPcoj.val = TRUE
    endif

    if (!this.tglSite.tag eq !type) then
      !this.tglSite.val = TRUE
    endif

    if (!this.tglZone.tag eq !type) then
      !this.tglZone.val = TRUE
    endif

    if (!this.tglPipe.tag eq !type) then
      !this.tglPipe.val = TRUE
    endif

    if (!this.tglStr.tag eq !type) then
      !this.tglStr.val = TRUE
    endif

    if (!this.tglRestr.tag eq !type) then
      !this.tglRestr.val = TRUE
    endif

    if (!this.tglEqu.tag eq !type) then
      !this.tglEqu.val = TRUE
    endif

    if (!this.tglHang.tag eq !type) then
      !this.tglHang.val = TRUE
    endif

    if (!this.tglSubs.tag eq !type) then
      !this.tglSubs.val = TRUE
    endif

    if (!this.tglFrmw.tag eq !type) then
      !this.tglFrmw.val = TRUE
    endif

    if (!this.tglSbfrm.tag eq !type) then
      !this.tglSbfrm.val = TRUE
    endif

    if (!this.tglPtr.tag eq !type) then
      !this.tglPtr.val = TRUE
    endif

    if ('CSURPX' eq !type) then
      !this.tglCSURPX.val = TRUE
    endif

    if ('CPANEL' eq !type) then
      !this.tglCSURPX.val = TRUE
    endif

    if ('HVAC' eq !type) then
      !this.tglHVAC.val = TRUE
    endif

    if ('HPANEL' eq !type) then
      !this.tglHPanel.val = TRUE
    endif

    if ('UPANEL' eq !type) then
      !this.tglUPanel.val = TRUE
    endif

    if ('STRFLT' eq !type) then
      !this.tglStrflt.val = TRUE
    endif

    if ('RLADDR' eq !type) then
      !this.tglRladdr.val = TRUE
    endif

    if ('SLADDR' eq !type) then
      !this.tglSladdr.val = TRUE
    endif

    if ('HANDRA' eq !type) then
      !this.tglHandra.val = TRUE
    endif

    if ('CONVEY' eq !type) then
      !this.tglConvey.val = TRUE
    endif

  enddo

endmethod
------------------------------------------------------------------------
--
-- Method:      GetSections
--
-- Description: Get the list of sections on the report significant list and set report tab toggles.
--
-- Method Type: Procedure
-- Arguments:
--   [#]    [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .getSections()

  --make table of actual settings control list
  !dtext = ARRAY()
  do !line values !this.lstSignificant.dtext
    !oneRow[1] = !line.split()[1]
    !oneRow[2] = !line.split()[2]
    !dtext.append(!oneRow)
  enddo

  if(!this.clasher.reportSignificantList.unset())then

    do !i indices !dtext
      !dtext[!i][2] = '-'
    enddo

  else

    --Set report significant control list
    do !i indices !dtext
         -- Clasher's report significant list uses 'SUPPO' but the control list uses 'SUPP' so
         -- 'SUPPO' must be searched for instead of 'SUPP'
         !searchValue = !dtext[!i][1]
         if (!searchValue eq 'SUPP') then
           !searchValue= 'SUPPO'
         endif
         if (!this.clasher.reportSignificantList.findFirst(!searchValue).set()) then
        !dtext[!i][2] = 'ON'
      else
        !dtext[!i][2] = 'OFF'
      endif
    enddo

  endif

  !this.lstSignificant.setRows(!dtext)

endmethod
------------------------------------------------------------------------
--
-- Method:      SetSections
--
-- Description: Set the list of sections on the report significant list and set report tab toggles.
--
-- Method Type: Procedure
-- Arguments:
--   [#]    [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setSections()

  -- read content from pointed line on significant list
  !selection = split(!this.lstSignificant.selection())
  !reportOption = !selection[1]
  !check = !selection[2]
  !this.setSections(!reportOption, !check)

endmethod

------------------------------------------------------------------------
--
-- Method:      SetSections
--
-- Description: Set the list of sections on the report significant list and set report tab toggles.
--
-- Method Type: Procedure
-- Arguments:
--   [#]    [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .setSections(!reportOption is STRING, !check is STRING)

   -- If necessary, replace 'SUPP' with 'SUPPO' as that is the valid clash option
   if (!reportOption eq |SUPP|) then
     !reportOption= |SUPPO|
   endif

  -- Enter DESCLASH mode
  !this.clasher.start()

  if (!check eq 'OFF') then
    !this.clasher.reportSignificantInclude(!reportOption)
  else
    !this.clasher.reportSignificantIgnore(!reportOption)
  endif

  -- exit DESCLASH mode
  !this.clasher.end()

  --Refresh clasher members
  !this.clasher.reportSettingsGet()

  !this.getSections()

endmethod

-- Common methods

------------------------------------------------------------------------
--
-- Method:      GraphicalSelectionHandler
--
-- Description: Append the picked element to the Pick list and changes the color
--              of the added element.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .graphicalSelectionHandler(!element is DBREF)

  ENHANCE $!<element> COLOUR RED
  !this.pickList.append(!element)

endmethod
------------------------------------------------------------------------
--
-- Method:      GetCurrentPdmsList
--
-- Description: Provides PDMS current list as list of DBREF.
--
-- Method Type: Function
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ARRAY       List of DBREF obtained from PDMS current list
--
------------------------------------------------------------------------
define method .getCurrentPdmsList() is ARRAY

  -- Check for current list
  !listObject = object LISTINTERFACE()

  -- If zero, then there is no list
  if(!listObject.hasCurrentList().not()) then
    !!alert.warning('No list defined')
    return ARRAY()
  endif

  !list = !listObject.getCurrentListAsReferences()

  -- Warning if List is empty
  if(!list.empty()) then
    !!alert.warning('List is empty')
  endif

  -- Returns list of DBREF
  return !list

endmethod
------------------------------------------------------------------------
--
-- Method:      GetCurrentSelection
--
-- Description: Provides current selection as list of DBREF.
--
-- Method Type: Function
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ARRAY       List of DBREF obtained from current selection
--
------------------------------------------------------------------------
define method .getCurrentSelection() is ARRAY

  -- Initialise Variables
  !selection              = object SELECTION()
  !selection.getCurrent()

  -- Selection list
  !selectionList          = !selection.getSelection()
  !list                   = !selectionList

  return !list

endmethod

-- Limits handling

------------------------------------------------------------------------
--
-- Method:      LimitsDisplay
--
-- Description: Displays the limits.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsDisplay()

  -- Store Limits
  !this.limitsStorePositions()

  -- Tag the new position
  !this.tag(!this.storedFromPosition, !this.storedToPosition)

endmethod
------------------------------------------------------------------------
--
-- Method:      fullLimitsClear
--
-- Description: Clears the limits - sets to 0.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .fullLimitsClear()

  -- clear limits in the clasher
  !this.limitsClear()

  !this.fromPosControl.xyz(0, 0, 0)
  !this.toPosControl.xyz(0, 0, 0)

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsClear
--
-- Description: Clears the limits.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsClear()

  -- clear limits in the clasher
  !this.clasher.start()
  !this.clasher.limitsClear()
  !this.clasher.end()

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsSet
--
-- Description: Sets the limits depending on the user selection.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsSet()

  if (!this.optLimitsSet.selection('RTEXT') eq 'Coordinates') then
    -- set limits to current element
    !this.limitsSetCoordinates()

  elseif (!this.optLimitsSet.selection('RTEXT') eq 'Explorer') then
    -- set limits to current element
    !this.limitsSetCE()

  elseif (!this.optLimitsSet.selection('RTEXT') eq 'Picked') then
    -- set limits to graphically selected elements
    !this.limitsInitGraphicalSelection()

  elseif (!this.optLimitsSet.selection('RTEXT') eq 'Origins') then
    -- set limits to origin of graphically selected element
    !this.limitsOriginsInitGraphicalSelection()

  elseif (!this.optLimitsSet.selection('RTEXT') eq 'List') then
    -- set limits to current pdms list of elements
    !this.limitsSetList()

  elseif (!this.optLimitsSet.selection('RTEXT') eq 'Selection') then
    -- set limits to current selection
    !this.limitsSetSelection()

  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsSetCoordinates
--
-- Description: Sets limits from the position control values
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsSetCoordinates()

  -- Initialise Variables
  !this.limitsStorePositions()
  !pos1 = !this.storedFromPosition
  !pos2 = !this.storedToPosition

  -- East0 North0 Up0 means no limits
  if (!pos1.east eq 0 and !pos1.north eq 0 and !pos1.up eq 0 and !pos2.east eq 0 and !pos2.north eq 0 and !pos2.up eq 0) then
    !this.limitsClear()
    return
  endif

  -- set limits in the clasher
  !this.clasher.start()
  !this.clasher.limitsSet(!this.storedFromPosition, !this.storedToPosition)
  !this.clasher.end()

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsStorePositions
--
-- Description: Store limits from the position control values
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsStorePositions()

  -- Initialise Variables
  !this.storedFromPosition       = object POSITION()
  !this.storedToPosition         = object POSITION()

  -- From Position
  !this.storedFromPosition       =  N0
  !newFromPos  = !this.fromPosControl.xyz()
  !this.storedFromPosition.east  = !newFromPos[0]
  !this.storedFromPosition.north = !newFromPos[1]
  !this.storedFromPosition.up    = !newFromPos[2]

  -- To Position
  !this.storedToPosition       =  N0
  !newToPos  = !this.toPosControl.xyz()
  !this.storedToPosition.east  = !newToPos[0]
  !this.storedToPosition.north = !newToPos[1]
  !this.storedToPosition.up    = !newToPos[2]

endmethod
------------------------------------------------------------------------
--
-- Method:      getSetLimits
--
-- Description: Gets and sets the limits
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .getSetLimits()

  --Get the limits from the clasher
  !positionARRAY = !this.clasher.limitsGet()

  --Set the limits to the position control
  if (!positionARRAY.unset()) then
    !this.fromPosControl.xyz(0, 0, 0)
    !this.toPosControl.xyz(0, 0, 0)
  else
    !this.fromPosControl.xyz(!positionARRAY[1].east, !positionARRAY[1].north, !positionARRAY[1].up)
    !this.toPosControl.xyz(!positionARRAY[2].east, !positionARRAY[2].north, !positionARRAY[2].up)
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsSetCE
--
-- Description: Sets limits by calculating enclosing box of CE.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsSetCE()

  -- set limits in the clasher
  !this.clasher.start()
  !this.clasher.limitsAutoSet(!!ce)
  !this.clasher.end()

  !this.getSetLimits()

  -- update limits in the form
  !this.limitsDisplay()

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsSetList
--
-- Description: Sets limits by calculating enclosing box of items from Current List.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsSetList()

  !list = !this.getCurrentPdmsList()

  if (!list.set()) then
    -- set limits from list
    !this.clasher.start()
    !this.clasher.limitsAutoSet(!list)
    !this.clasher.end()

    !this.getSetLimits()

    -- display limits
    !this.limitsDisplay()
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      limitsSetSelection
--
-- Description: Sets limits by calculating enclosing box of items from Current Selection.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsSetSelection()

  !list = !this.getCurrentSelection()

  if (!list.set()) then
    -- set limits from list
    !this.clasher.start()
    !this.clasher.limitsAutoSet(!list)
    !this.clasher.end()

    !this.getSetLimits()

    -- display limits
    !this.limitsDisplay()
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsInitGraphicalSelection
--
-- Description: Sets limits by calculating enclosing box of picked items.
--
-- Method Type: Procedure
--
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsInitGraphicalSelection()

  -- clear graphical selection list
  !this.pickList.clear()

  -- Define event packet for picking elements
  !packet                = object EDGPACKET()
  !packet.elementPick('Pick element to add to list for enclosing box (<ESC> to end)')
  !packet.action         = '!!avaclasherui.graphicalSelectionHandler(!this.return[1].item)'
  !packet.escape         = '!!avaclasherui.limitsGraphicalSelectionFinished()'
  !packet.description    = 'Clasher - Pick Element for enclosing box'

  -- Add into EDG packet
  !!edgCntrl.add(!packet)

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsOriginsInitGraphicalSelection
--
-- Description: Sets limits by calculating enclosing box of picked items origins.
--
-- Method Type: Procedure
--
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsOriginsInitGraphicalSelection()

  !packet = object EDGPACKET()
  !packet.definePosition('Pick First Clash Limit')
  !packet.priority    = 1
  !packet.remove      = false
  !packet.action = '!!avaclasherui.limitsOriginsSecondGraphicalSelection(!this.return[1].position.wrt(worl))'
  !packet.description = 'Clasher - Pick First Clash Limit'
  !!edgCntrl.add(!packet)

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsOriginsSecondGraphicalSelection
--
-- Description: Sets limits by calculating enclosing box of picked items origins.
--
-- Method Type: Procedure
--
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsOriginsSecondGraphicalSelection(!firstPosition is POSITION)

  pin 1 at $!firstPosition
  !this.storedFromPosition = !firstPosition

  !packet = object EDGPACKET()
  !packet.definePosition('Pick Second Clash Limit')
  !packet.priority    = 1
  !packet.remove      = false
  !packet.action = '!!avaclasherui.limitsOriginsGraphicalSelectionFinished(!!avaclasherui.storedFromPosition, !this.return[1].position.wrt(worl))'
  !packet.escape = 'PIN1 OFF'
  !packet.description = 'Clasher - Pick Second Clash Limit'
  !!edgCntrl.add(!packet)

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsGraphicalSelectionFinished
--
-- Description: The methods sets clasher limits to the box enclosing list
--              of elements. It takes care of de-selection.
--
-- Method Type: Procedure
--
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsGraphicalSelectionFinished()

  if (!this.pickList.size() eq 0) then
    return
  endif

  do !i indices !this.pickList
    UNENHANCE $!this.pickList[$!i]
  enddo

  -- set limits from list
  !this.clasher.start()
  !this.clasher.limitsAutoSet(!this.pickList)
  !this.clasher.end()

  !this.getSetLimits()

  -- display limits
  !this.limitsDisplay()

endmethod
------------------------------------------------------------------------
--
-- Method:      LimitsOriginsGraphicalSelectionFinished
--
-- Description: Sets the limits based on the 2 positions.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .limitsOriginsGraphicalSelectionFinished(!firstPosition is POSITION, !secondPosition is POSITION)

  !this.storedFromPosition = !firstPosition
  !this.storedToPosition   = !secondPosition
  !!edgCntrl.remove('Pick First Clash Limit')
  !!edgCntrl.remove('Pick Second Clash Limit')

  -- set limits from list
  !this.clasher.start()
  !this.clasher.limitsSet(!firstPosition, !secondPosition)
  !this.clasher.end()

  !this.getSetLimits()

  -- display limits
  !this.limitsDisplay()

endmethod

-- Obstructions/Exclusions lists handling

-- Common

------------------------------------------------------------------------
--
-- Method:      ObstExclInitGraphicalSelection
--
-- Description: Initialises graphical selection of elements. The results are
--              stored on obstruction or exclusion list depending on given
--              parameter.
--
-- Method Type: Procedure
--
-- Arguments:
--   [#]    [R/RW] [Data Type] [Description]
--   !type   R      STRING      Destination for selected elements. Could be 'OBSTRUCTIONS' or 'EXCLUSIONS'.
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstExclInitGraphicalSelection(!type is STRING)

  !this.frmObstructions.active = FALSE

  -- clear graphical selection list
  !this.pickList.clear()

  -- Define event packet for picking elements
  !packet                = object EDGPACKET()
  !packet.elementPick('Pick element to add (<ESC> to add list)')
  !packet.action         = '!!avaclasherui.graphicalSelectionHandler(!this.return[1].item)'
  !packet.description    = 'Clasher - Pick Element'

  -- Define the escape action according to type of list
  if (!type eq 'OBSTRUCTIONS') then
    !packet.escape         = '!!avaclasherui.obstExclGraphicalSelectionFinished(|OBSTRUCTIONS|)'
  elseif (!type eq 'EXCLUSIONS') then
    !packet.escape         = '!!avaclasherui.obstExclGraphicalSelectionFinished(|EXCLUSIONS|)'
  endif

  -- Add into EDG packet
  !!edgCntrl.add(!packet)

endmethod
------------------------------------------------------------------------
--
-- Method:      ObstExclGraphicalSelectionFinished()
--
-- Description: UNENHANCE red coloured elements and add list to obstruction list.
--
-- Method Type: Procedure
--
-- Arguments:
--   [#]             [R/RW] [Data Type] [Description]
--    !destination    R      STRING      Defines destination list. Could be 'OBSTRUCTIONS' or 'EXCLUSIONS'
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstExclGraphicalSelectionFinished(!destination is STRING)
  -- deselecting elements
  do !i indices !this.pickList
    -- Element deselected
    UNENHANCE $!this.pickList[$!i]
  enddo

  if (!destination eq 'OBSTRUCTIONS') then
    -- add list to obstruction list
    !!avaclasherui.obstListAddElements(!this.pickList)
  else
    -- add list to obstruction list
    !!avaclasherui.exclListAddElements(!this.pickList)
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      RemButtonActiveNot
--
-- Description: Sets Remove button inactive in frame Obstruction and
--              in frame Exclusion.
--
-- Method Type: Procedure
-- Arguments:
--   [#]       [R/RW] [Data Type] [Description]
--    !object     R      GADGET       Gadget passed to open callback.
--    !action     R      STRING       Type of action passed to open callback method.
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .remButtonActiveNot( !dummyObject is GADGET, !action is STRING)

  --if frame is shown
  if (!action eq 'SHOWN') then

    --grey out Remove buttons
    !this.btnObstRem.active = FALSE
    !this.btnExclRem.active = FALSE

    --clear selection on lists
    !this.lstObst.clearSelection()
    !this.lstExcl.clearSelection()

  endif

endmethod

-- Exclusion list

------------------------------------------------------------------------
--
-- Method:      ExclListRemove
--
-- Description: Removes selected element from exclusion lists.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListRemove()

  -- Get selection from the exclusion list
  !selection = !this.lstExcl.selection()

  --If the selection is not defined, return
  if (!selection.unset() or !selection.trim().empty()) then
    !this.btnExclRem.active = FALSE
    return
  endif

  -- Get the index of selected item
  !index = !selection.split(' ')[1].real()

  -- Start DESCLASH, Removes the element from the exclusion list and EXIT DESCLASH.
  !this.clasher.start()
  !flag = !this.clasher.exclusionRemoveAt(!index)
  !this.clasher.end()

  -- Updates the Exclusion list on the form or execute the Warning.
  if (!flag) then
    !this.displayExcl()
  else
    !!alert.warning('This element is not on the list')
  endif

  -- Sets Remove button inactive
  !this.btnExclRem.active = FALSE

endmethod
------------------------------------------------------------------------
--
-- Method:      ExclListClear
--
-- Description: Clears the exclusion list.
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListClear()

  -- Asks if the User is sure to clear the exclusion list.
  !answer = !!alert.confirm('Are you sure You Want to Clear the exclusion list?')

  -- If User is sure - exclusion list is cleared.
  if (!answer eq 'YES') then

    -- Start DESCLASH, Removes all the element from the exclusion list, EXIT DESCLASH and updates the exclusion list on the form.
    !this.clasher.start()
    !this.clasher.exclusionClear()
    !this.clasher.end()
    !this.displayExcl()

    --grey out Remove button btnExclRem
    !this.btnExclRem.active = FALSE

  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      ExclListAdd
--
-- Description: Selects the type of adding to the exclusion list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListAdd()

  -- Selects the type of adding to the exclusion list according to the selection made by the User
  if (!this.optExclAdd.selection('RTEXT') eq 'Explorer') then
    -- Add CE
    !this.exclListAddCE()

  elseif (!this.optExclAdd.selection('RTEXT') eq 'Picked') then
    -- Add Picked elements
    !this.exclListInitGraphicalSelection()

  elseif (!this.optExclAdd.selection('RTEXT') eq 'Selection') then
    -- Add Picked elements
    !this.exclListAddSelection()

  elseif (!this.optExclAdd.selection('RTEXT') eq 'List') then
    -- Add current list
    !this.exclListAddList()
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      ExclListAddCE
--
-- Description: Add selected CE to the exclusion list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListAddCE()

  -- Set the element to be added to the exclusion list
  !element = !!ce

  -- Start DESCLASH, Add the element to the exclusion list and EXIT DESCLASH.
  !this.clasher.start()
  !flag = !this.clasher.exclusionAdd(!element)
  handle ANY
    !!alert.error(!!error.text.after(')').trim())
    !this.clasher.end()
    return
  endhandle
  !this.clasher.end()

  -- Updates the Exclusion list on the form or execute the Warning.
  if (!flag) then
    !this.displayExcl()
  else
    !!alert.warning('This element is already on the list')
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      ExclListAddList
--
-- Description: Adds Current List to exclusion list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListAddList()

  -- Initiate empty list
  !list = ARRAY()

  -- converts the list of names (STRINGs) to list of DBREF
  !list = !this.getCurrentPdmsList()

  -- Add list of elements do exclusion list
  if (!list.set()) then
    !this.exclListAddElements(!list)
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      ExclListAddSelection
--
-- Description: Adds current selection to exclusion list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListAddSelection()

  -- Selection list
  !list        = !this.getCurrentSelection()

  -- Add list of elements do exclusion list
  if (!list.set()) then
    !this.exclListAddElements(!list)
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      ExclListInitGraphicalSelection
--
-- Description: Adds picked element from 3d view to exclusion list.
--
-- Method Type: Procedure
-- Arguments:
--   [#]    [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListInitGraphicalSelection()

  !this.obstExclInitGraphicalSelection('EXCLUSIONS')

endmethod
------------------------------------------------------------------------
--
-- Method:      DisplayExcl
--
-- Description: Displays the exclusion list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .displayExcl()

  --Define variables
  !this.exclusionList  = object ARRAY()
  !rtext  = object ARRAY()

  --Get the current selection
  !dbrefList = !this.clasher.exclusionListGet()

  --Fill the temporary list
  do !index indices !dbrefList
    !this.exclusionList[!index][1] =  !index.string() & ' '
    !this.exclusionList[!index][2] =  '# ' & !dbrefList[!index].parnam
    handle ANY
      !this.exclusionList[!index][2] =  !dbrefList[!index].fullname
    endhandle
    if (!this.exclusionList[!index][2] eq '# ') then
      !this.exclusionList[!index][2] =  !dbrefList[!index].fullname
    endif
    !rtext[!index] = !index.string()
  enddo

  -- Set Exclusion List
  !this.lstExcl.setRows(!this.exclusionList)
  !this.lstExcl.rtext = !rtext

endmethod
------------------------------------------------------------------------
--
-- Method:      ExclListAddElements
--
-- Description: Adds list of elements (DBREF) to the exclusion list.
--
-- Method Type: Procedure
--
-- Arguments:
--   [#]       [R/RW] [Data Type] [Description]
--    !list     R      ARRAY       List of elements (DBREF).
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .exclListAddElements(!list is ARRAY)

  -- Sets Obstruction / Exclusion form to Active
  !this.frmObstructions.active = TRUE

  -- Define variable
  !elementsString = STRING()
  !elementsStringTooLong = false

  -- Adds all elements from the list using do loop
  !countErrors = 0
  do !index indices !list

    !element = !list[!index]

    -- Starts DESCLASH, adds element to the exclusion list and EXIT DESCLASH
    !this.clasher.start()
    !flag = !this.clasher.exclusionAdd(!element)
    handle ANY
      !countErrors = !countErrors + 1
      if (!countErrors le 3) then
        !!alert.error(!!error.text.after(')').trim())
      endif
      !this.clasher.end()
      skip
    endhandle
    !this.clasher.end()

    -- Give a general account of errors
    if (!index eq !list.size() and !countErrors gt 3) then
      !!alert.error('A total of ' & !countErrors.string() & ' elements could not be added' )
    endif

    -- Prepares the list of elements to be displayed at Warning information
    if (!flag eq FALSE and !elementsStringTooLong eq FALSE) then

      if (!elementsString.set()) then
        !elementsString = !elementsString & !element.name & ' | '
        handle ANY
          -- Text could get too long
          !elementsString = !elementsString.trim() & '>'
          !elementsStringTooLong = TRUE
        endhandle
      else
        !elementsString= ' | ' & !element.name & ' | '
      endif

    endif

  enddo

  -- Display Warning
  if (!elementsString.set()) then
    !!alert.warning('Element(s) ' & !elementsString& ' already on the list')
    handle ANY
      !!alert.warning('Several elements are already on the list')
    endhandle
  endif
  -- Updates the exclusion list on the form
  !this.displayExcl()

endmethod
------------------------------------------------------------------------
--
-- Method:      RemExclButtonActive
--
-- Description: Sets Remove button active in frame Obstruction.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .remExclButtonActive()

  !this.btnExclRem.active = TRUE

endmethod

-- Obstruction list

------------------------------------------------------------------------
--
-- Method:      DisplayObst
--
-- Description: Displays the obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .displayObst()

  --Define variables
  !this.obstructionList  = object ARRAY()
  !rtext  = object ARRAY()
  !world = /*

  --Get the current selection
  !dbrefList = !this.clasher.obstructionListGet()

  --Fill the temporary list
  do !index indices !dbrefList
    !this.obstructionList[!index][1] =  !index.string() & ' '

    if (!dbrefList[!index].name.dbref() eq !world) then
      !this.obstructionList[!index][2] = 'ALL'
    else
      -- Do we have a part name
      !this.obstructionList[!index][2] =  '# ' & !dbrefList[!index].parnam
      handle ANY
        !this.obstructionList[!index][2] =  !dbrefList[!index].fullname
      endhandle
      -- Avoid any blank part name
      if (!this.obstructionList[!index][2] eq '# ') then
        !this.obstructionList[!index][2] =  !dbrefList[!index].fullname
      endif
    endif

    !rtext[!index] = !index.string()
  enddo

  -- Set Obstruction List
  !this.lstObst.setRows(!this.obstructionList)
  !this.lstObst.rtext = !rtext

endmethod
------------------------------------------------------------------------
--
-- Method:      ObstListRemove
--
-- Description: Removes selected element from the obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListRemove()

  -- Get selection from the obstruction list
  !selection = !this.lstObst.selection()

  --If the selection is not defined, return
  if (!selection.unset() or !selection.trim().empty()) then
    !this.btnObstRem.active = FALSE
    return
  endif

  -- Get the index of selected item
  !index = !selection.split(' ')[1].real()

  -- Start DESCLASH, Removes the element from the obstruction list and EXIT DESCLASH.
  !this.clasher.start()
  !flag = !this.clasher.obstructionRemoveAt(!index)
  !this.clasher.end()

  -- Updates the Obstruction list on the form or execute the Warning.
  if (!flag) then
    !this.displayObst()
  else
    !!alert.warning('This element is not on the list')
  endif

  -- Sets Remove button inactive
  !this.btnObstRem.active = FALSE

endmethod
------------------------------------------------------------------------
--
-- Method:      ObstListClear
--
-- Description: Clears the obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListClear()

  -- Asks if the User is sure to clear the obstruction list.
  !answer = !!alert.confirm('Are you sure You Want to Clear the obstruction list?')

  -- If User is sure - obstruction list is cleared.
  if (!answer eq 'YES') then

    -- Start DESCLASH, Removes all the element from the obstruction list, EXIT DESCLASH and updates the obstruction list on the form.
    !this.clasher.start()
    !this.clasher.obstructionClear()
    !this.clasher.end()
    !this.displayObst()

    --grey out Remove button btnObstRem
    !this.btnObstRem.active = FALSE

  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      ObstListAdd
--
-- Description: Selects the type of adding to the obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListAdd()

  -- Selects the type of adding to the exclusion list according to the selection made by the User
  if (!this.optObstAdd.selection('RTEXT') eq 'Explorer') then
    -- Add CE
    !this.obstListAddCE()

  elseif (!this.optObstAdd.selection('RTEXT') eq 'Picked') then
    -- Add Picked elements
    !this.obstListInitGraphicalSelection()

  elseif (!this.optObstAdd.selection('RTEXT') eq 'Selection') then
    -- Add current list
    !this.obstListAddSelection()

  elseif (!this.optObstAdd.selection('RTEXT') eq 'List') then
    -- Add current list
    !this.obstListAddList()

  elseif (!this.optObstAdd.selection('RTEXT') eq 'Laser') then
    -- Add current list
    !this.obstListAddLaser()

  elseif (!this.optObstAdd.selection('RTEXT') eq 'All') then
    -- Add ALL
    !this.obstListAddAll()
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      ObstListAddElements
--
-- Description: Add list of elements (DBREF) to the obstruction list.
--
-- Method Type: Procedure
--
-- Arguments:
--   [#]       [R/RW] [Data Type] [Description]
--    !list     R      ARRAY       List of elements (DBREF)
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListAddElements(!list is ARRAY)

  -- Sets Obstruction / Exclusion form to Active
  !this.frmObstructions.active = TRUE

  -- Define variables
  !elementsString= STRING()
  !elementsStringTooLong = FALSE

  -- Adds all elements from the list using do loop
  !countErrors = 0
  do !index indices !list

    !element = !list[!index]

    -- Prepares the list of elements to be displayed at Warning information
    !this.clasher.start()
    !flag = !this.clasher.obstructionAdd(!element)
    handle ANY
      !countErrors = !countErrors + 1
      if (!countErrors le 3) then
        !!alert.error(!!error.text.after(')').trim())
      endif
      !this.clasher.end()
      skip
    endhandle
    !this.clasher.end()

    -- Give a general account of errors
    if (!index eq !list.size() and !countErrors gt 3) then
      !!alert.error('A total of ' & !countErrors.string() & ' elements could not be added' )
    endif

    -- Prepares the list of elements to be displayed at Warning information
    if (!flag eq FALSE and !elementsStringTooLong eq FALSE) then
      if (!elementsString.set()) then
        !elementsString = !elementsString& !element.name & ' | '
        handle ANY
          -- Text could get too long
          !elementsString = !elementsString.trim() & '>'
          !elementsStringTooLong = TRUE
        endhandle
      else
        !elementsString= ' | ' & !element.name & ' | '
      endif
    endif

  enddo

  -- Display Warning
  if (!elementsString.set()) then
    !!alert.warning('Element(s) ' & !elementsString & ' already on the list')
    handle ANY
      !!alert.warning('Several elements are already on the list')
    endhandle
  endif

  -- Updates the exclusion list on the form
  !this.displayObst()

endmethod
------------------------------------------------------------------------
--
-- Method:      RemObsButtonActive
--
