-- Arguments:
--   [#]    [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListInitGraphicalSelection()

  !this.obstExclInitGraphicalSelection('OBSTRUCTIONS')

endmethod
------------------------------------------------------------------------
--
-- Method:      ObstListAddAll
--
-- Description: Adds ALL to the obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListAddAll()

  !element = /*
  !this.obstListAddElement(!element)

endmethod
------------------------------------------------------------------------
--
-- Method:      ObstListAddCE
--
-- Description: Adds CE to obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListAddCE()

  !this.obstListAddElement(!!ce)

endmethod
------------------------------------------------------------------------
--
-- Method:      ObstListAddElement
--
-- Description: Adds given element to the obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListAddElement(!element is DBREF)

  -- Start DESCLASH, Add the element to the obstruction list and EXIT DESCLASH.
  !this.clasher.start()
  !flag = !this.clasher.obstructionAdd(!element)
  handle ANY
    !!alert.error(!!error.text.after(')').trim())
    !this.clasher.end()
    return
  endhandle
  !this.clasher.end()

  -- Updates the Obstruction list on the form or execute the Warning.
  if (!flag) then
    !this.displayObst()
  else
    !!alert.warning('This element is already on the list or all elements are on the list')
  endif

endmethod

------------------------------------------------------------------------
--
-- Method:      GetCurrentXGEOMList
--
-- Description: Provides XGEOMS in display as list of DBREF.
--
-- Method Type: Function
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--    ARRAY       List of DBREF obtained from PDMS current list
--
------------------------------------------------------------------------
define method .getCurrentXGEOMList() is ARRAY

  !list        = object ARRAY()

  VAR !drawlist COLLECT ALL FROM drawlist
  do !elementString values !drawlist
    !element = !elementString.dbref()
    if (!element.type eq 'XGEOM') then
      !list.append(!element)
    endif
  enddo

  -- Warning if List is empty
  if(!list.empty()) then
    !!alert.warning('No laser models in display')
  endif

  -- Returns list of DBREFs
  return !list

endmethod

------------------------------------------------------------------------
--
-- Method:      ObstListAddLaser
--
-- Description: Adds XGEOMs in display to obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListAddLaser()

  -- Initiate empty list
  !list = ARRAY()

  -- converts the list of names (STRINGs) to list of DBREF
  !list = !this.getCurrentXGEOMList()

  -- Add list of elements to obstruction list
  if (!list.set()) then
    !this.obstListAddElements(!list)
  endif

endmethod

------------------------------------------------------------------------
--
-- Method:      ObstListAddList
--
-- Description: Adds Current List to obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListAddList()

  -- Initiate empty list
  !list = ARRAY()

  -- converts the list of names (STRINGs) to list of DBREF
  !list = !this.getCurrentPdmsList()

  -- Add list of elements to obstruction list
  if (!list.set()) then
    !this.obstListAddElements(!list)
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      ObstListAddSelection
--
-- Description: Adds current selection to obstruction list.
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .obstListAddSelection()

  -- Selection list
  !list        = !this.getCurrentSelection()

  -- Add list of elements to obstruction list
  if (!list.set()) then
    !this.obstListAddElements(!list)
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      activeInactiveReportOptions
--
-- Description: Activate or deactivate report options
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .activeInactiveReportOptions()

  if (!this.tglRepSave.val eq true) then
    !this.frmPos.active       = true
    !this.frmDup.active       = true
    !this.frmLvl.active       = true
    !this.frmSigOption.active = true
    !this.frmObstr.active     = true
    !this.frmRepExp.active    = true
  else
    !this.frmPos.active       = false
    !this.frmDup.active       = false
    !this.frmLvl.active       = false
    !this.frmSigOption.active = false
    !this.frmObstr.active     = false
    !this.frmRepExp.active    = false
  endif

  -- Temporarily inactive Report Position Site
  if (!this.marine) then
    !this.tglPosSt.active = false
  endif

endmethod
------------------------------------------------------------------------
--
-- Method:      activeInactiveClipOptions
--
-- Description: Activate or deactivate clip options
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .activeInactiveClipOptions()

  if (!this.tglClip.val eq true) then
    !this.txtClip.active = true
    !this.clipSlider.active = true
  else
    !this.txtClip.active = false
    !this.clipSlider.active = false
  endif

endmethod

-- Grid control methods
------------------------------------------------------------------------
--
-- Method:  netPopupMainCallback
--
-- Description: main grid popup callback
--
-- Method Type: Procedure
-- [#] [R/RW] [Data Type] [Description]
-- Return:
-- [Data Type] [Description]
--
------------------------------------------------------------------------
define method .netPopupMainCallback(!a is ARRAY)

  !this.netFrame.popup = !this.popmenumain
  !this.netFrame.showPopup(!a[0], !a[1])

endmethod
--End of method definition .netPopupMainCallback()
------------------------------------------------------------------------
--
-- Method:      netAfterSelectChangeCallback
--
-- Description:
--
-- Method Type: Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .netAfterSelectChangeCallback(!a is ARRAY)

  -- To avoid double callback when calling popup
  if (!a.unset()) then
    -- returned
    return
  endif

  if (!this.dbCtrl.getSelectedRows().set()) then

    !this.clipClash()

    !clashItemString = !this.dbCtrl.getSelectedRows()[1][15]
    !clashItem       = !clashItemString.dbref()
    handle any
      !this.selectedParagraph.val = 'The clash item has been deleted since this clash report was generated'
      return
    endhandle
    !obstructionItemString = !this.dbCtrl.getSelectedRows()[1][16]
    !obstructionItem   = !obstructionItemString.dbref()
    handle any
      !this.selectedParagraph.val = 'The obstruction item has been deleted since this clash report was generated'
      return
    endhandle

    -- !clashType = !clashItem.type
    -- !obstructionType = !obstructionItem.type

    if (!this.togNav.val) then
      if (!this.optNav.selection() eq 'ITEM') then
        !!ce = !clashItem
      else
        !!ce = !obstructionItem
      endif
    endif

  endif

  -- Construct a long string
  !array = !this.dbCtrl.getSelectedRows()[1]
  !stringA = '| ' & !array[1] & ' | ' & !array[2] & ' | ' & !array[3] & ' | ' & !array[4] & ' | ' & !array[5]
  !stringB = !array[6] & ' | X ' & !array[10] & 'Y ' & !array[11] & 'Z ' & !array[12] & ' | ' & !array[13]
  !stringC = !array[14] & ' | '
  !string = !stringA & ' | ' & !stringB & ' | ' & !stringC
  !this.selectedParagraph.val = 'Selected Clash: ' & !string

endmethod
--------------------------------------------------------------------------
--
-- Method:      fileBrowserLoad
--
-- Description: Load the PML fileBrowser to Save the location of the Report File
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--
-- Return:
--   [Data Type] [Description]
--
---------------------------------------------------------------------------
define method .fileBrowserLoad()

  using namespace 'Aveva.Core.Presentation'

  !browser = object PMLFILEBROWSER('SAVE')

  -- Show Browser

  var !userEvar '%AVEVA_DESIGN_USER%'

  !browser.show(!userEvar, 'MyReport.txt', 'Clash Report', false, 'txt files (*.txt)|*.txt', 2)

  !fileName = !browser.file()

  !this.txtFile.val = !fileName
  handle ANY
  endhandle

endmethod
-- End of method definition for .fileBrowserLoad()
------------------------------------------------------------------------
--
-- Method:      posControl()
--
-- Description: Method called every time the posControl gadgets change via the .changeAction
--
-- Method Type: Procedure
--   [#] [R/RW] [Data Type] [Description]
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .posControl()

  -- Store Positions
  !this.limitsSetCoordinates()

  -- Tag the new position
  !this.tag(!this.storedFromPosition, !this.storedToPosition)

endmethod
------------------------------------------------------------------------
--
-- Method:      tag
--
-- Description: Tag position
--
-- Method Type: Procedure
--   [#] [R/RW] [Data Type] [Description]
--    1    R     POSITION    Position to tag
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .tag(!fromPosition is POSITION, !toPosition is POSITION)

  -- Initialise Variables
  !!aidClear(!this.limitsAid.string(), 'ALL')

  if (!this.togLimitsAids.val.not()) then
    return
  endif

  -- Do not do this if positions are E0
  if (!fromPosition.distance(!toPosition).eq(0)) then
    return
  endif

  -- Text description
  !fromText = |Clash -From- Limit|
  !toText   = |Clash -To- Limit|

  -- Key positions for aid box
  !wsd = object POSITION('E ' & !fromPosition.east & ' N ' & !fromPosition.north & ' U ' & !fromPosition.up & ' wrt /* ')
  !wnd = object POSITION('E ' & !fromPosition.east & ' N ' & !toPosition.north   & ' U ' & !fromPosition.up & ' wrt /* ')
  !end = object POSITION('E ' & !toPosition.east   & ' N ' & !toPosition.north   & ' U ' & !fromPosition.up & ' wrt /* ')
  !esd = object POSITION('E ' & !toPosition.east   & ' N ' & !fromPosition.north & ' U ' & !fromPosition.up & ' wrt /* ')
  !enu = object POSITION('E ' & !toPosition.east   & ' N ' & !toPosition.north   & ' U ' & !toPosition.up   & ' wrt /* ')
  !esu = object POSITION('E ' & !toPosition.east   & ' N ' & !fromPosition.north & ' U ' & !toPosition.up   & ' wrt /* ')
  !wsu = object POSITION('E ' & !fromPosition.east & ' N ' & !fromPosition.north & ' U ' & !toPosition.up   & ' wrt /* ')
  !wnu = object POSITION('E ' & !fromPosition.east & ' N ' & !toPosition.north   & ' U ' & !toPosition.up   & ' wrt /* ')

  -- Aid info
  AID TEXT NUMBER $!<this.limitsAid> '$!fromText' AT $!fromPosition
  AID TEXT NUMBER $!<this.limitsAid> '$!toText'   AT $!toPosition
  -- Bottom Lines
  AID LINE NUMBER $!<this.limitsAid> $!wsd  to $!wnd
  AID LINE NUMBER $!<this.limitsAid> $!wnd  to $!end
  AID LINE NUMBER $!<this.limitsAid> $!end  to $!esd
  AID LINE NUMBER $!<this.limitsAid> $!esd  to $!wsd
  -- Top Lines
  AID LINE NUMBER $!<this.limitsAid> $!enu  to $!esu
  AID LINE NUMBER $!<this.limitsAid> $!esu  to $!wsu
  AID LINE NUMBER $!<this.limitsAid> $!wsu  to $!wnu
  AID LINE NUMBER $!<this.limitsAid> $!wnu  to $!enu
  -- Vertical Lines
  AID LINE NUMBER $!<this.limitsAid> $!enu  to $!end
  AID LINE NUMBER $!<this.limitsAid> $!esu  to $!esd
  AID LINE NUMBER $!<this.limitsAid> $!wsu  to $!wsd
  AID LINE NUMBER $!<this.limitsAid> $!wnu  to $!wnd

endmethod

---------------------------------------------------------------------------
--
-- Method:      saveMain
--
-- Description: Saves the main grid to an excel file
--
-- Method Type: Procedure
-- [#] [R/RW] [Data Type] [Description]
-- Return:
-- [Data Type] [Description]
--
------------------------------------------------------------------------
define method .saveMain(!fileName is STRING)

  using namespace 'Aveva.Core.Presentation'
  !browser = object PMLFILEBROWSER('SAVE')
  !browser.show('%AVEVA_DESIGN_USER%', !fileName, 'Save to Excel', false, 'xls files (*.xls)|*.xls|xlsx files (*.xlsx)|*.xlsx',1)

  if (!browser.file().neq('')) then
    --Save grid dat to excel file
    !this.dbCtrl.saveGridToExcel(!browser.file())
    handle NONE
      !!alert.message('File $!fileName saved')
    elsehandle NONE
      !!alert.error('Could not save to Excel')
    endhandle
  endif

endmethod
--End of method definition .saveMain()
---------------------------------------------------------------------------
--
-- Method:      fileName
--
-- Description: gets the file name to output the grid data
--
-- Method Type: Procedure
-- [#] [R/RW] [Data Type] [Description]
-- Return:
-- [Data Type] [Description]
--  STRING      full file name
--
------------------------------------------------------------------------
define method .fileName() is STRING

  !clock     = object DATETIME()
  !time      = !clock.string()
  !time      = !time.replace(':','-')
  !fileName  = |Clashes -| & !time & |.xls|

  return !fileName

endmethod
--End of method definition .fileName()

------------------------------------------------------------------------
--
-- Method:      sliderCallback
--
-- Description: parameter change callback
--
-- Method Type: Function/Procedure
-- Arguments:
--   [#] [R/RW] [Data Type] [Description]
--    1    R      ANY         Slider gadget that raised the event
--    2    R      STRING      Action required
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .sliderCallback(!gadget is ANY, !action is STRING)

  if (!this.dbCtrl.getRows().size() eq 0) then
    !gadget.val      = 0
    return
  endif

  -- Check if clip is set, fall out if not
  if (!this.tglClip.val.not()) then
    return
  endif

  if (!this.txtClip.val.unset()) then
    !this.txtClip.val = !this.memoryBox
  endif

  -- Stopped moving the slider reset
  if (!action eq 'STOP') then
    if (!this.txtClip.val lt 0 ) then
      !this.txtClip.val = !this.memoryBox
    endif
    !gadget.val      = 0
  endif

  -- Slider is being dragged
  if (!gadget eq !this.clipSlider) then
    if (!action eq 'START') then
      !this.memoryBox = !this.txtClip.val
    elseif (!action eq 'MOVE') then
      !this.txtClip.val   = !this.memoryBox + !gadget.val
      !this.txtClip.refresh()
    endif
  endif

  -- Recalculate the boundary
  !this.clipClash()

endmethod
-- End of method
------------------------------------------------------------------------
--
-- Method:      ceCallback
--
-- Description: Clash CE text box callback
--
-- Method Type: Function/Procedure
-- Arguments:
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .ceCallback()

  $!this.parClash.val
  handle NONE
    !this.parClash.val = !!ce.name
  elsehandle ANY
    -- Try a slash
    /$!this.parClash.val
    handle NONE
      !this.parClash.val = !!ce.name
    elsehandle ANY
      !!alert.error('Invalid Element')
      !this.parClash.val = !!ce.name
    endhandle
  endhandle

endmethod
-- End of method
------------------------------------------------------------------------
--
-- Method:      groupOptionCallback
--
-- Description: Group the clashes option
--
-- Method Type: Function/Procedure
-- Arguments:
-- Return:
--   [Data Type] [Description]
--
------------------------------------------------------------------------
define method .groupOptionCallback()

  -- Group Clashes in the .net grid
  if (!this.tglPresentGroup.val) then
    !this.dbCtrl.setGroupByColumn(13, true)
    !this.dbCtrl.setGroupByColumn(14, true)
  else
    !this.dbCtrl.setGroupByColumn(13, false)
    !this.dbCtrl.setGroupByColumn(14, false)
  endif

endmethod
-- End of method

-----------------------------------------------------------------------
--
-- Method:      checkSupport
--
-- Description: provide a list of supports to be checked by .checkSupportList()
--
--
------------------------------------------------------------------------
define method .checkSupport(!selectNew is BOOLEAN)

  if (!selectNew) then
    --get a new list of supports
    !this.clasher = object AVACLASHER()
    !this.supportMem = object ARRAY()
    !!findSupports = object MDSFINDSUPPORTS()
    !edgCallbackObject = ARRAY()
    !edgCallbackObject[1] = !!avaclasherui
    !!findSupports.find(false, 'QUERY', !edgCallbackObject, 'Identify supports for Clasher check - Escape to finish')
  else
    -- check the existing support list
    !this.checkSupportList()
  endif

endmethod
-----------------------------------------------------------------------
--
-- Method:      .checkSupportList()
--
-- Description: return from picking supports to clash and check
--
--
------------------------------------------------------------------------
define method .checkSupportList()

  --If user does not pick the support or support member, then return.
  if (!this.supportMem.size().eq(0)) then
    return
  endif

  !this.clasher.start()
  !this.clasher.clashesWithinIgnore('STRU')
  !this.clasher.clashesWithinIgnore('SUPP')

  do !element values !this.supportMem
    !this.clasher.exclusionAdd(!element)
  enddo

  !this.clasher.end()
  !this.findClashes(!this.supportMem)
  !this.setIgnored()

  !this.showClashes(!this.supportMem.first())
  !this.clasher.start()
  !this.clasher.exclusionClear()
  !this.clasher.end()

  if (!this.supportMem.set() and !this.supportMem.size() gt 0) then
    !this.btnSupportRecheck.active = true
  endif
  if (!this.supportMem.set() and !this.supportMem.size() gt 0) then
    !this.parSupportSelected.val = 'Selected: ' + !this.supportMem[1].name
  else
    !this.parSupportSelected.val = ''
  endif

endmethod

-----------------------------------------------------------------------
--
-- Method:      .edgCallback()
--
-- Description: return from picking supports to clash and check
--
--
------------------------------------------------------------------------

define method .edgCallback()

  !suppoList = !!findSupports.selectedSupports
  !this.supportMem = !suppoList
  !this.checkSupportList()

endmethod

-----------------------------------------------------------------------
--
-- Method:      .highlight()
--
-- Description: return from picking supports to clash and check
--
--
------------------------------------------------------------------------

define method .highlight(!element is DBREF, !colourCode is REAL, !tube is BOOLEAN)

  if (!tube) then
    ENHANCE TOTAL LEAVE TUBE OF $!element COLOUR $!colourCode
    handle any
    endhandle
  else
    ENHANCE $!element COLOUR $!colourCode
    handle any
    endhandle
  endif

endmethod
