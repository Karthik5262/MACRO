 Define method .collections()
 
 !filename = 'C:/TEMP/PIPE.txt'
 
 !fileobj = object file(!filename)
 !filecontent = !fileobj.readfile()
 
 Do !pip from 1 to !filecontent.size()
    !piptmp = !filecontent[!pip]
     $!piptmp temp 50degc
