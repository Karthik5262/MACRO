 -- $p $!pip
 
 
 endmethod
 
---------------------------------------------------------------
Define method .pra1()

  --!Paraname = para of N3
  
  ---$p $!paraname
  
  --define method .reordercomp()

 
!list = object LIST()
!members = !!collect(all members)
 
-- Filter out elements and store names/references
do !x from 1 to !members.size() 
    !name = !members[!x].name
    !list.append(!name + '|' + !members[!x].string())
enddo
 
-- Sort the list alphabetically
!list.sort()
 
-- Apply the reorder
do !x from 1 to !list.size()
    !parts = !list[!x].split('|')
    !ref = !parts[2]
    
    -- Move the element to the position of the current index
    REORDER $!ref BEFORE $!x
enddo
 
$P Reordering complete.
 

endmethod 
 
 --endmethod 
